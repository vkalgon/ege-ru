          <label>Тип формы</label>
          <div class="task10-check-grid">
            <label><input type="checkbox" class="task12-gen-form-cb" value="verb"> глаголы</label>
            <label><input type="checkbox" class="task12-gen-form-cb" value="active_part"> действит. причастия</label>
            <label><input type="checkbox" class="task12-gen-form-cb" value="passive_part"> страдат. причастия</label>
