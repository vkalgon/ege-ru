    </div>

    <div class="admin-section" style="overflow-x:auto;">
      <table class="admin-table" id="words-table" style="table-layout:auto;width:100%;">
        <thead>
          <tr>
            <th>Слово</th><th>Буква</th><th>Правило</th>
            <th>Спр.</th><th>Инфинитив</th><th>Группа</th><th>Действия</th>
          </tr>
        </thead>
        <tbody id="words-tbody">
          <tr><td colspan="7" style="color:var(--text-secondary);">Загрузка...</td></tr>
        </tbody>
      </table>
