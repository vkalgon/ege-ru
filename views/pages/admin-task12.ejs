      </div>
      <div class="form-group">
        <label>Фильтр: тип формы</label>
        <select id="filter-form-type" onchange="loadWords12()">
          <option value="">Все</option>
          <option value="verb">Глаголы</option>
          <option value="active_part">Действит. причастия</option>
          <option value="passive_part">Страдат. причастия</option>
          <option value="wsh">ВШ (отвлекатели)</option>
          <option value="nn">НН (отвлекатели)</option>
