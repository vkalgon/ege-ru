<div class="admin-page">
  <h2 class="admin-page__title">Задание №12 — Управление</h2>

  <div class="admin-task-tabs-bar">
    <button class="tab-btn active" onclick="switchTab('words',this)">Словарь слов</button>
    <button class="tab-btn" onclick="switchTab('tasks',this)">Готовые задания</button>
    <button class="tab-btn" onclick="switchTab('generate',this)">Генерация</button>
    <button class="tab-btn" onclick="switchTab('groups',this)">Группы вариантов</button>
  </div>

  <!-- ══ ВКЛАДКА: СЛОВАРЬ ══════════════════════════════════ -->
  <div id="tab-words">
    <div class="admin-section">
      <h3>Добавить слово</h3>

      <div style="background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:8px;padding:12px 16px;margin-bottom:16px;font-size:13px;line-height:1.6;">
        <strong>Пары букв:</strong><br>
        <b>е/и</b> — окончания 1/2 л. ед.ч. (пиш<b>..</b>шь / стро<b>..</b>шь) и суффиксы страд. причастий (-ем- / -им-)<br>
        <b>у/а</b> — 3 л. мн.ч. с твёрд. согл. (они пиш<b>..</b>т / дыш<b>..</b>т) и действит. причастия (пиш<b>..</b>щий / дыш<b>..</b>щий)<br>
        <b>ю/я</b> — 3 л. мн.ч. с мягк. согл. (они бор<b>..</b>тся / стро<b>..</b>т) и действит. причастия (бор<b>..</b>щийся / стро<b>..</b>щий)<br>
        <b>Тип «ВШ — отвлекатель»</b> — действит. прич. прош. вр.: переносим <em>любую</em> букву из н.ф. (написАть → написАвший, построИть → построИвший)<br>
        <b>Тип «НН — отвлекатель»</b> — страдат. прич. прош. вр.: -ать/-ять → -анн-/-янн-, иначе → -енн- (написАнный, построЕнный)
      </div>

      <form id="word-form" class="admin-form">
        <input type="hidden" id="word-id">
        <div class="word-form-grid">
          <div class="form-group">
            <label>Слово с пропуском</label>
            <input type="text" id="word-display" placeholder="пиш..т" required oninput="onWordDisplayInput()">
            <div style="color:var(--text-secondary);font-size:12px;margin-top:4px;">Используйте <code>..</code> для пропуска</div>
            <div id="dup-warning" style="display:none;margin-top:4px;font-size:12px;color:#f59e0b;"></div>
          </div>
          <div class="form-group">
            <label>Правильная буква
              <span id="letter-auto-badge" style="display:none;margin-left:6px;font-size:11px;font-weight:400;color:var(--text-secondary);background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:4px;padding:1px 6px;">авто</span>
              <button type="button" id="letter-reset-btn" onclick="resetLetterManual()" style="display:none;margin-left:6px;font-size:11px;font-weight:400;background:none;border:none;color:var(--text-secondary);cursor:pointer;padding:0;text-decoration:underline;">сбросить</button>
            </label>
            <select id="word-letter" required onchange="onLetterManual()">
              <option value="">—</option>
              <option value="е">е</option>
              <option value="и">и</option>
              <option value="у">у</option>
              <option value="ю">ю</option>
              <option value="а">а</option>
              <option value="я">я</option>
            </select>
          </div>
          <div class="form-group">
            <label>Пара букв</label>
            <select id="word-pair" required onchange="autoFillRule()">
              <option value="">—</option>
              <option value="е/и">е / и</option>
              <option value="у/а">у / а</option>
              <option value="ю/я">ю / я</option>
            </select>
          </div>
          <div class="form-group">
            <label>Тип формы</label>
            <select id="word-form-type" required onchange="onFormTypeManual()">
              <option value="">—</option>
              <option value="verb">Глагол (личное окончание)</option>
              <option value="active_part">Действит. причастие (-ущ/-ющ/-ащ/-ящ-)</option>
              <option value="passive_part">Страдат. причастие (-ем-/-им-)</option>
              <option value="wsh">ВШ — отвлекатель (переносим букву н.ф.)</option>
              <option value="nn">НН — отвлекатель (-анн-/-янн-/-енн-)</option>
            </select>
          </div>
          <div class="form-group">
            <label>Спряжение
              <span id="conj-auto-badge" style="display:none;margin-left:6px;font-size:11px;font-weight:400;color:var(--text-secondary);background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:4px;padding:1px 6px;">авто</span>
              <button type="button" id="conj-reset-btn" onclick="resetConjManual()" style="display:none;margin-left:6px;font-size:11px;font-weight:400;background:none;border:none;color:var(--text-secondary);cursor:pointer;padding:0;text-decoration:underline;">сбросить</button>
            </label>
            <select id="word-conjugation" onchange="onConjChange()">
              <option value="">— (для ВШ/НН не нужно)</option>
              <option value="1">I спряжение</option>
              <option value="2">II спряжение</option>
            </select>
          </div>
          <div class="form-group">
            <label>Инфинитив</label>
            <input type="text" id="word-base-verb" placeholder="писать" oninput="onBaseVerbInput()">
          </div>
          <div class="form-group">
            <label>Правило / пояснение
              <span id="rule-auto-badge" style="display:none;margin-left:6px;font-size:11px;font-weight:400;color:var(--text-secondary);background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:4px;padding:1px 6px;">авто</span>
            </label>
            <input type="text" id="word-rule" placeholder="заполнится автоматически" oninput="onRuleInput()">
          </div>
        </div>

        <div id="extra-group" style="margin-top:12px;">
          <div class="form-group" style="max-width:320px;">
            <label>Группа вариантов <span style="color:var(--text-secondary);font-weight:400;">(ID или пусто)</span></label>
            <div style="display:flex;gap:8px;align-items:center;">
              <input type="number" id="word-group-id" placeholder="—" min="1" style="width:80px;">
              <button type="button" class="btn btn-secondary btn-sm" id="btn-new-group" style="display:none;" onclick="createNewGroup12()">Новая группа</button>
              <span id="group-hint" style="font-size:13px;color:var(--text-secondary);"></span>
            </div>
            <div id="group-auto-hint" style="font-size:12px;margin-top:4px;"></div>
          </div>
        </div>

        <div style="display:flex;gap:8px;margin-top:12px;">
          <button type="submit" class="btn" id="word-submit-btn">Добавить</button>
          <button type="button" class="btn btn-secondary" id="word-cancel-btn" style="display:none;" onclick="cancelWordEdit12()">Отмена</button>
        </div>
      </form>
    </div>

    <!-- Фильтры -->
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;max-width:720px;margin-bottom:16px;">
      <div class="form-group">
        <label>Фильтр: пара букв</label>
        <select id="filter-pair" onchange="loadWords12()">
          <option value="">Все</option>
          <option value="е/и">е / и</option>
          <option value="у/а">у / а</option>
