  </div>

  <!-- ══ ВКЛАДКА: ГЕНЕРАЦИЯ ════════════════════════════════ -->
  <div id="tab-generate" style="display:none;">
    <div class="admin-section">
      <h3>Сгенерировать задание</h3>
      <p style="color:var(--text-secondary);font-size:14px;margin-bottom:16px;">
        5 случайных слов из словаря, из них N с верным ударением.
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;max-width:600px;margin-bottom:16px;">
        <div class="form-group">
          <label>Правильных слов</label>
          <select id="gen-correct-count">
            <option value="2">2</option>
            <option value="3" selected>3</option>
            <option value="4">4</option>
          </select>
        </div>
        <div class="form-group">
          <label>Категория (необязательно)</label>
          <select id="gen-category">
            <option value="">Любая</option>
            <option value="past_fem_verb">Прош. вр. ж.р.</option>
            <option value="short_part_fem">Кратк. прич. ж.р.</option>
            <option value="verb_it">Глаголы на -ИТЬ</option>
            <option value="verb_from_adj">Глаголы от прил.</option>
            <option value="active_part_vsh">Прич. -ВШ-</option>
            <option value="part_bent">Прич. загнуть/согнуть</option>
            <option value="part_enn">Прич. -ЁНН-</option>
            <option value="bal_root">Корень БАЛ-</option>
            <option value="gerund_vsh">Деепр. -ВШ-</option>
            <option value="foreign_noun">Иностр. сущ.</option>
            <option value="deverbal_noun">Отглагольные сущ.</option>
            <option value="fixed_stress">Неподвижное ударение</option>
            <option value="adj_from_noun">Прилаг. от сущ.</option>
            <option value="krasivee">КрасИвее</option>
            <option value="adv_do">Наречия ДО-</option>
            <option value="adv_za">Наречия ЗА-</option>
          </select>
        </div>
        <div class="form-group">
          <label>Количество заданий</label>
          <input type="number" id="gen-tasks-count" min="1" max="20" value="1" style="max-width:100px;">
        </div>
      </div>
      <button class="btn" id="btn-generate-task">Сгенерировать и сохранить</button>
      <div id="gen-result" style="margin-top:14px;"></div>
    </div>

    <div class="admin-section" style="margin-top:32px;">
      <h3>Сгенерированные задания</h3>
