<div class="admin-page">
  <h2 class="admin-page__title">Задание №4 — Орфоэпический минимум</h2>

  <div class="admin-task-tabs-bar">
    <button class="tab-btn active" onclick="switchTab('words',this)">Словарь</button>
    <button class="tab-btn" onclick="switchTab('tasks',this)">Готовые задания</button>
    <button class="tab-btn" onclick="switchTab('generate',this)">Генерация</button>
  </div>

  <!-- ══ ВКЛАДКА: СЛОВАРЬ ══════════════════════════════════ -->
  <div id="tab-words">
    <div class="admin-section">
      <h3 id="word-form-title">Добавить слово</h3>
      <form id="word-form" class="admin-form" onsubmit="return false;">
        <input type="hidden" id="word-id">

        <div class="word-form-grid">
          <div class="form-group" style="grid-column:1/-1;">
            <label>Слово (без знаков ударения)</label>
            <input type="text" id="word-input" placeholder="звонить" required
              autocomplete="off" oninput="rebuildPicker()" style="max-width:320px;">
            <div style="margin-top:4px;font-size:12px;color:var(--text-secondary);">
              Введите слово, затем кликните на букву, чтобы назначить ударения.
            </div>
          </div>

          <div class="form-group" style="grid-column:1/-1;">
            <div style="display:flex;gap:40px;flex-wrap:wrap;">
              <div>
                <label style="margin-bottom:6px;display:block;">
                  Верное ударение
                  <span style="color:var(--brand);font-size:13px;margin-left:6px;" id="preview-correct"></span>
                </label>
                <div id="picker-correct" class="t4-picker-row"></div>
                <input type="hidden" id="correct-stress-index">
              </div>
              <div>
                <label style="margin-bottom:6px;display:block;">
                  Ошибочное ударение
                  <span style="color:#f59e0b;font-size:13px;margin-left:6px;" id="preview-wrong"></span>
                </label>
                <div id="picker-wrong" class="t4-picker-row"></div>
                <input type="hidden" id="wrong-stress-index">
              </div>
            </div>
          </div>

          <div class="form-group">
            <label>Категория</label>
            <select id="word-category">
              <option value="past_fem_verb">Глаголы прош. вр. ж.р.</option>
              <option value="short_part_fem">Краткие причастия ж.р.</option>
              <option value="verb_it">Глаголы на -ИТЬ</option>
              <option value="verb_from_adj">Глаголы от прилагательных</option>
              <option value="active_part_vsh">Причастия с -ВШ-</option>
              <option value="part_bent">Причастия загнуть/согнуть</option>
              <option value="part_enn">Причастия с -ЁНН-</option>
              <option value="bal_root">Корень БАЛ-</option>
              <option value="gerund_vsh">Деепричастия с -ВШ-</option>
              <option value="foreign_noun">Иностр. существительные</option>
              <option value="deverbal_noun">Отглагольные существительные</option>
              <option value="fixed_stress">Неподвижное ударение</option>
              <option value="adj_from_noun">Прилагательные от сущ.</option>
              <option value="krasivee">Степени сравнения красИвый</option>
              <option value="adv_do">Наречия с ДО-</option>
              <option value="adv_za">Наречия с ЗА-</option>
              <option value="other" selected>Другое</option>
            </select>
          </div>

          <div class="form-group">
            <label>Часть речи</label>
            <select id="word-pos">
              <option value="noun">существительное</option>
              <option value="verb" selected>глагол</option>
              <option value="adj">прилагательное</option>
              <option value="participle">причастие</option>
              <option value="gerund">деепричастие</option>
              <option value="adverb">наречие</option>
              <option value="other">другое</option>
            </select>
          </div>

          <div class="form-group" style="align-self:end;">
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
              <input type="checkbox" id="word-exception">
              Исключение из правила
            </label>
          </div>

          <div class="form-group" style="grid-column:1/-1;">
            <label>Подсказка <span style="color:var(--text-secondary);font-weight:400;">(необязательно)</span></label>
            <input type="text" id="word-hint" placeholder="Исключение: вЫлила — приставка ВЫ- всегда ударна" style="max-width:480px;">
          </div>
        </div>

        <div style="margin-top:16px;display:flex;gap:10px;flex-wrap:wrap;">
          <button type="button" class="btn" id="word-submit-btn" onclick="submitWord()">Добавить</button>
          <button type="button" class="btn btn-secondary" id="word-cancel-btn" style="display:none;" onclick="resetWordForm()">Отмена</button>
        </div>
        <div id="word-form-error" style="color:#D69295;margin-top:8px;display:none;"></div>
      </form>
    </div>

    <div class="admin-section">
      <h3>Словарь <span id="words-count" style="color:var(--text-secondary);font-weight:400;font-size:15px;"></span></h3>
      <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center;margin-bottom:14px;">
        <input type="text" id="words-search" placeholder="Поиск..." style="max-width:200px;" oninput="filterWords()">
        <select id="filter-category" onchange="filterWords()" style="max-width:260px;">
          <option value="">Все категории</option>
          <option value="past_fem_verb">Прош. вр. ж.р.</option>
          <option value="short_part_fem">Кратк. прич. ж.р.</option>
          <option value="verb_it">Глаголы на -ИТЬ</option>
          <option value="verb_from_adj">Глаголы от прил.</option>
          <option value="active_part_vsh">Прич. -ВШ-</option>
          <option value="part_bent">Прич. загнуть/согнуть</option>
          <option value="part_enn">Прич. -ЁНН-</option>
          <option value="bal_root">Корень БАЛ-</option>
          <option value="gerund_vsh">Деепр. -ВШ-</option>
          <option value="foreign_noun">Иностр. сущ.</option>
          <option value="deverbal_noun">Отглагольные сущ.</option>
          <option value="fixed_stress">Неподвижное ударение</option>
          <option value="adj_from_noun">Прилаг. от сущ.</option>
          <option value="krasivee">КрасИвее</option>
          <option value="adv_do">Наречия ДО-</option>
          <option value="adv_za">Наречия ЗА-</option>
          <option value="other">Другое</option>
        </select>
        <label style="display:flex;align-items:center;gap:6px;font-size:14px;cursor:pointer;">
          <input type="checkbox" id="filter-exception" onchange="filterWords()"> Только исключения
        </label>
      </div>
      <table class="admin-table" id="words-table">
        <thead>
          <tr>
            <th style="color:var(--brand);">Верное ударение</th>
            <th style="color:#f59e0b;">Ошибочное ударение</th>
            <th>Категория</th>
            <th>Подсказка</th>
            <th>Действия</th>
          </tr>
        </thead>
        <tbody id="words-tbody">
          <tr><td colspan="5" style="color:var(--text-secondary);">Загрузка...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ══ ВКЛАДКА: ГОТОВЫЕ ЗАДАНИЯ ══════════════════════════ -->
  <div id="tab-tasks" style="display:none;">
    <div class="admin-section">
      <h3>Составить задание вручную</h3>
      <p style="color:var(--text-secondary);font-size:14px;margin-bottom:16px;">
        Выберите 5 слов, отметьте те, в которых ударение указано <strong>верно</strong> (2–4 слова).
      </p>
      <div id="task-builder">
        <div id="task-slots" style="display:flex;flex-direction:column;gap:10px;"></div>
        <div style="display:flex;gap:8px;margin-top:16px;flex-wrap:wrap;align-items:center;">
          <button type="button" class="btn" id="btn-save-task">Сохранить задание</button>
          <button type="button" class="btn btn-secondary" id="task-edit-cancel" style="display:none;" onclick="cancelTaskEdit()">Отмена</button>
