<div class="task-page" id="task4-list">
  <h2 class="task-page__title">Задание №4 — Орфоэпические нормы (ударения)</h2>

  <div class="task17-wrapper">
    <div class="task9-column task9-feed-inner">

      <h3 class="task10-section-title">Сгенерировать задание</h3>
      <div class="task10-generate-wrap" style="margin-bottom:32px;">
        <div class="task10-generate-grid task9-generate-grid">
          <div class="form-group" style="margin:0;">
            <label>Правильных слов</label>
            <div class="task10-check-grid task10-count-grid">
              <label><input type="checkbox" class="task4-count-checkbox" value="2" checked> 2</label>
              <label><input type="checkbox" class="task4-count-checkbox" value="3"> 3</label>
              <label><input type="checkbox" class="task4-count-checkbox" value="4"> 4</label>
            </div>
          </div>
          <div class="form-group" style="margin:0;">
            <label>Количество заданий</label>
            <input type="number" id="task4-tasks-count" min="1" max="20" value="1">
          </div>
        </div>
        <div class="task10-generate-actions">
          <button class="btn" id="btn-generate-task4" type="button">Сгенерировать</button>
        </div>
      </div>

      <h3 class="task10-section-title">Все задания</h3>
      <div id="tasks-feed" class="task9-task-feed">
        <p style="color:var(--text-secondary);margin:0;">Загрузка...</p>
      </div>

    </div>
  </div>
</div>

<style>
.t4-items { display: flex; flex-direction: column; gap: 10px; }

.t4-item {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 12px 18px;
  background: var(--bg-secondary);
  border: 1px solid var(--glass-border);
  border-radius: 8px;
  transition: border-color 0.2s ease, background 0.2s ease;
}
.t4-item.selected       { border-color: var(--brand);        background: var(--brand-muted); }
.t4-item.result-correct { border-color: var(--brand);        background: var(--brand-muted); }
.t4-item.result-missed  { border-color: #f59e0b;             background: rgba(245,158,11,0.06); }
.t4-item.result-wrong   { border-color: #D69295;             background: rgba(214,146,149,0.08); }
.t4-item.result-neutral { border-color: var(--glass-border); opacity: 0.65; }

.t4-num {
  width: 32px; height: 32px;
  border-radius: 6px;
  border: 1px solid var(--glass-border);
  background: none; cursor: pointer;
  font-size: 14px; font-weight: 700;
  color: var(--text-secondary);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
}
.t4-num:hover:not(:disabled) { border-color: var(--brand); color: var(--brand); }
.t4-num.selected { border-color: var(--brand); color: var(--brand); background: var(--brand-muted); }
.t4-num:disabled { cursor: default; }

.t4-word { font-size: 20px; cursor: default; }

.t4-ch {
  cursor: pointer;
  border-radius: 3px;
}
.t4-ch:hover { background: rgba(255,255,255,0.08); }
.t4-ch.marked { background: rgba(245,158,11,0.35); }
.t4-ch.locked { cursor: default; }
.t4-ch.locked:hover { background: none; }
.t4-ch.answer-ch { color: var(--brand); font-weight: 700; }


.t4-result-block { display: flex; flex-direction: column; gap: 10px; margin-top: 4px; }
.t4-result-row   { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; line-height: 1.5; }
.t4-result-icon  { font-weight: 700; width: 18px; flex-shrink: 0; padding-top: 1px; }
.t4-rule         { margin-top: 3px; font-size: 12px; color: var(--text-secondary); }

.t4-tut-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.25);
  z-index: 9999;
  pointer-events: none; /* фон не блокирует клики */
}
.t4-tut-card {
  pointer-events: auto; /* но кнопки кликабельны */
  width: 100%;
  max-width: 560px;
  background: var(--bg-secondary);
  border: 1px solid var(--glass-border);
  border-radius: 12px;
  padding: 16px 16px 14px;
  box-shadow: 0 10px 40px rgba(0,0,0,0.35);
}
.t4-tut-title {
  font-weight: 800;
  margin-bottom: 6px;
}
.t4-tut-text {
  margin: 0 0 12px;
  color: var(--text-secondary);
  line-height: 1.5;
  font-size: 14px;
}
.t4-tut-actions {
  display: flex;
  gap: 10px;
  justify-content: flex-end;
}
.t4-tut-btn {
  border-radius: 10px;
  border: 1px solid var(--glass-border);
  background: none;
  padding: 10px 12px;
  cursor: pointer;
  color: var(--text-secondary);
  font-weight: 700;
}
.t4-tut-btn:hover { border-color: var(--brand); color: var(--brand); }
.t4-tut-btn--primary {
  border-color: var(--brand);
  color: var(--brand);
  background: rgba(255,255,255,0.06);
}
.t4-tut-highlight {
  outline: 2px solid var(--brand);
  outline-offset: 2px;
  background: rgba(245,158,11,0.20);
}
.t4-tut-blink {
  animation: t4TutBlink 1s ease-in-out infinite;
}

@keyframes t4TutBlink {
  0% {
    outline-color: var(--brand);
    background: rgba(245,158,11,0.20);
  }
  50% {
    outline-color: #fbbf24;
    background: rgba(245,158,11,0.40);
  }
  100% {
    outline-color: var(--brand);
    background: rgba(245,158,11,0.20);
  }
}

.t4-help-fab {
  position: fixed;
  right: 24px;
  bottom: 24px;
  width: 48px;
  height: 48px;
  border-radius: 999px;
  border: 1px solid var(--glass-border);
  background: var(--glass-bg);
  backdrop-filter: var(--glass-backdrop);
  -webkit-backdrop-filter: var(--glass-backdrop);
  color: var(--text-secondary);
  font: 700 20px/1 "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  cursor: pointer;
  box-shadow: var(--shadow-glass);
  z-index: 9000;
  transition: border-color 0.2s ease, color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
}
.t4-help-fab:hover {
  border-color: var(--brand);
  color: var(--brand);
  box-shadow: var(--shadow-neon), var(--shadow-glass);
  transform: translateY(-1px);
}
</style>

<script>
function escHtml(s) {
  return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function stressIdx(word, wordStressed) {
  const p = wordStressed.indexOf('\u0301');
  return p >= 1 ? p - 1 : -1;
}

function renderWord(word, stressIndex, itemIndex) {
  return Array.from(word).map((ch, i) => {
    const display = i === stressIndex ? ch.toUpperCase() : ch;
    return `<span class="t4-ch" data-item="${itemIndex}" data-pos="${i}">${escHtml(display)}</span>`;
  }).join('');
}

function renderAnswerWord(word, correctIndex) {
  return Array.from(word).map((ch, i) => {
    if (i === correctIndex)
      return `<span class="t4-ch locked answer-ch">${ch.toUpperCase()}</span>`;
    return `<span class="t4-ch locked">${escHtml(ch)}</span>`;
  }).join('');
}

function renderPlayCard(taskId, task) {
  const itemsHtml = task.items.map(it => `
    <div class="t4-item" id="t4-item-${taskId}-${it.item_index}">
      <button class="t4-num" data-index="${it.item_index}">${it.item_index}</button>
      <span class="t4-word" id="t4-word-${taskId}-${it.item_index}">
        ${renderWord(it.word, stressIdx(it.word, it.word_stressed), it.item_index)}
      </span>
    </div>
  `).join('');

  return `
    <div class="task-card task17-card task9-play-card">
      <div class="task-meta">
        <span class="task-meta__number">№ 4</span>
        <span class="task-meta__source">Задание #${taskId}</span>
      </div>
      <div class="task-content">
        <p class="task-prompt task9-instruction" style="margin:0 0 18px;">
          Укажите варианты ответов, в которых <strong>верно</strong> выделено ударение.
          Запишите номера ответов.
        </p>
        <div class="t4-items" id="t4-items-${taskId}">${itemsHtml}</div>
        <div class="task-controls task9-task-controls">
          <input
            type="text" id="t4-input-${taskId}"
            class="task-input"
            placeholder="Номера ответов — впишите вручную или выберите слева"
            inputmode="numeric"
            autocomplete="off"
          >
          <button type="button" class="task-send" id="t4-check-${taskId}">Проверить</button>
          <button type="button" class="btn btn-secondary task9-back-btn" id="t4-solution-btn-${taskId}">Решение</button>
        </div>
        <div id="t4-solution-${taskId}" style="display:none;margin-top:16px;"></div>
        <div id="t4-result-${taskId}" style="display:none;margin-top:16px;"></div>
      </div>
    </div>`;
}

function parseInput(str) {
  const set = new Set();
  for (const ch of String(str || '').replace(/\s|,/g, '')) {
    const d = parseInt(ch, 10);
    if (!Number.isNaN(d) && d >= 1 && d <= 9) set.add(d);
  }
  return set;
}

function renderSolution(taskId, data) {
  const correctStr = data.correct_indices.join(', ');
  let html = `<div class="task-card task17-card" style="padding:16px 20px;">
    <div class="task-meta" style="margin-bottom:14px;">
      <span class="task-meta__number">Решение</span>
      <span class="task-meta__source">Правильный ответ: <strong>${correctStr}</strong></span>
    </div>
    <div class="t4-result-block">`;

  data.items.forEach(item => {
    const ci = item.correct_stress_index;
    const correctDisplay =
      escHtml(item.word.slice(0, ci)) +
      `<strong style="color:var(--brand);">${item.word[ci].toUpperCase()}</strong>` +
      escHtml(item.word.slice(ci + 1));

    const badge = item.is_correct
      ? `<span style="color:var(--brand);font-weight:600;">✓ верно</span>`
      : `<span style="color:var(--text-secondary);">✗ неверно</span>`;

    let ruleHtml = '';
    if (item.category_rule) {
      const exc = item.is_exception
        ? '<span style="background:rgba(245,158,11,.15);color:#f59e0b;border-radius:3px;padding:1px 5px;font-size:11px;margin-left:4px;">исключение</span>'
        : '';
      ruleHtml = `<div class="t4-rule">${escHtml(item.category_name)}${exc}: ${escHtml(item.category_rule)}</div>`;
    }
    if (item.hint)
      ruleHtml += `<div class="t4-rule">${escHtml(item.hint)}</div>`;

    html += `<div class="t4-result-row">
      <span style="font-size:15px;flex-shrink:0;">${item.item_index}.</span>
      <div>${correctDisplay} — ${badge}${ruleHtml}</div>
    </div>`;
  });

  html += `</div></div>`;
  return html;
}

function initPlayCard(taskId) {
  const selected    = new Set();
  const grid        = document.getElementById('t4-items-' + taskId);
  const checkBtn    = document.getElementById('t4-check-' + taskId);
  const inputEl     = document.getElementById('t4-input-' + taskId);
  const resultEl    = document.getElementById('t4-result-' + taskId);
  const solutionBtn = document.getElementById('t4-solution-btn-' + taskId);
  const solutionEl  = document.getElementById('t4-solution-' + taskId);

  function syncButtonsFromSelected() {
    grid.querySelectorAll('.t4-num').forEach(btn => {
      const idx = +btn.dataset.index;
      const card = document.getElementById('t4-item-' + taskId + '-' + idx);
      if (selected.has(idx)) {
        btn.classList.add('selected');
        card.classList.add('selected');
      } else {
        btn.classList.remove('selected');
        card.classList.remove('selected');
      }
    });
  }

  function syncInputFromSelected() {
    inputEl.value = Array.from(selected).sort((a, b) => a - b).join('');
  }

  /* Клики по кнопкам-номерам → обновить selected + поле */
  grid.addEventListener('click', e => {
    const numBtn = e.target.closest('.t4-num');
    if (numBtn && !numBtn.disabled) {
      const idx = +numBtn.dataset.index;
      if (selected.has(idx)) selected.delete(idx);
      else selected.add(idx);
      syncButtonsFromSelected();
      syncInputFromSelected();
      return;
    }

    const ch = e.target.closest('.t4-ch');
    if (ch && !ch.classList.contains('locked')) {
      const itemIdx = ch.dataset.item;
      grid.querySelectorAll(`.t4-ch[data-item="${itemIdx}"]`)
        .forEach(l => { if (l !== ch) l.classList.remove('marked'); });
      ch.classList.toggle('marked');
    }
  });

  /* Ввод в поле → обновить selected + кнопки */
  inputEl.addEventListener('input', () => {
    const parsed = parseInput(inputEl.value);
    selected.clear();
    parsed.forEach(v => selected.add(v));
    syncButtonsFromSelected();
  });

  /* Enter в поле → проверить */
  inputEl.addEventListener('keydown', e => {
    if (e.key === 'Enter') checkBtn.click();
  });

  solutionBtn.addEventListener('click', async () => {
    if (solutionEl.dataset.loaded === '1') {
      const open = solutionEl.style.display !== 'none';
      solutionEl.style.display = open ? 'none' : 'block';
      solutionBtn.textContent = open ? 'Решение' : 'Скрыть решение';
      return;
    }
    solutionBtn.disabled = true;
    try {
      const res = await fetch('/api/task4/tasks/' + taskId + '/solution');
      if (!res.ok) throw new Error('Не удалось загрузить решение');
      const data = await res.json();
      solutionEl.innerHTML = renderSolution(taskId, data);
      solutionEl.dataset.loaded = '1';
      solutionEl.style.display = 'block';
      solutionBtn.textContent = 'Скрыть решение';
      solutionEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    } catch (e) {
      alert(e.message || 'Ошибка');
    } finally {
      solutionBtn.disabled = false;
    }
  });

  checkBtn.addEventListener('click', async () => {
    checkBtn.disabled = true;
    checkBtn.textContent = '...';
    try {
      const res = await fetch('/api/task4/tasks/' + taskId + '/check', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ selected: Array.from(selected) })
      });
      const data = await res.json();
      if (data.error) { alert(data.error); return; }

      grid.querySelectorAll('.t4-ch').forEach(c => c.classList.add('locked'));
      grid.querySelectorAll('.t4-num').forEach(b => b.disabled = true);
      inputEl.disabled = true;
      checkBtn.style.display = 'none';

      renderResult(taskId, data, resultEl);
    } finally {
      checkBtn.disabled = false;
      checkBtn.textContent = 'Проверить';
    }
  });
}

async function maybeStartTutorialForTask(taskId, task) {
  try {
    if (window.__t4TutorialStarted) return;

    const meRes = await fetch('/api/auth/me');
    if (!meRes.ok) return;
    const me = await meRes.json();
    if (!me?.success) return;
    if (me.user?.task4_mechanics_done) return;

    window.__t4TutorialStarted = true;
    startTutorialForTask(taskId, task);
  } catch {
    // ignore
  }
}

function startTutorialForTask(taskId, task) {
  if (!task?.items?.length) return;

  const grid = document.getElementById('t4-items-' + taskId);
  if (!grid) return;

  let step = 1;
  const firstItem = task.items[0];
  const stressIndex = stressIdx(firstItem.word, firstItem.word_stressed);
  if (stressIndex < 0) return;

  const firstLetters = grid.querySelectorAll(`.t4-ch[data-item="${firstItem.item_index}"]`);
  const correctLetter = grid.querySelector(
    `.t4-ch[data-item="${firstItem.item_index}"][data-pos="${stressIndex}"]`
  );
  if (!correctLetter) return;

  const overlay = document.createElement('div');
  overlay.className = 't4-tut-overlay';
  overlay.innerHTML = `
    <div class="t4-tut-card">
      <div class="t4-tut-title" id="t4-tut-title"></div>
      <p class="t4-tut-text" id="t4-tut-text"></p>
      <div class="t4-tut-actions">
        <button type="button" class="t4-tut-btn t4-tut-btn--primary" id="t4-tut-done" style="display:none;">Понятно</button>
      </div>
    </div>
  `;
  document.body.appendChild(overlay);

  const cardEl = overlay.querySelector('.t4-tut-card');
  const titleEl = overlay.querySelector('#t4-tut-title');
  const textEl = overlay.querySelector('#t4-tut-text');
  const doneBtn = overlay.querySelector('#t4-tut-done');

  let markingDone = false;
  async function markDone() {
    if (markingDone) return;
    markingDone = true;
    try {
      await fetch('/api/auth/onboarding/task-mechanics/done', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({})
      });
    } catch {
      // ignore
    }

    grid.querySelectorAll('.t4-tut-highlight, .t4-tut-blink').forEach(el => {
      el.classList.remove('t4-tut-highlight', 't4-tut-blink');
    });
    overlay.remove();
  }

  doneBtn.addEventListener('click', markDone);

  function clearHighlights() {
    grid.querySelectorAll('.t4-tut-highlight, .t4-tut-blink').forEach(el => {
      el.classList.remove('t4-tut-highlight', 't4-tut-blink');
    });
  }

  function positionOverlayToElement(targetEl) {
    if (!cardEl || !targetEl) return;
    const rect = targetEl.getBoundingClientRect();
    const cardW = cardEl.offsetWidth || 560;
    const padding = 12;

    let left = rect.left + rect.width / 2;
    left = Math.max(padding + cardW / 2, Math.min(window.innerWidth - padding - cardW / 2, left));

    const topAbove = rect.top - padding;
    const shouldPlaceAbove = rect.top > 160;
    const top = shouldPlaceAbove ? topAbove : rect.bottom + padding;

    cardEl.style.position = 'fixed';
    cardEl.style.left = left + 'px';
    cardEl.style.top = top + 'px';
    cardEl.style.transform = shouldPlaceAbove ? 'translate(-50%, -100%)' : 'translate(-50%, 0)';
  }

  function renderStep() {
    if (step === 1) {
      doneBtn.style.display = 'none';
      titleEl.textContent = 'Шаг 1 из 3';
      textEl.textContent = 'Нажмите на букву, чтобы выделить ударную в слове.';

      clearHighlights();
      correctLetter.classList.add('t4-tut-highlight', 't4-tut-blink');
      requestAnimationFrame(() => positionOverlayToElement(correctLetter));
    }

    if (step === 2) {
      doneBtn.style.display = 'none';
      titleEl.textContent = 'Шаг 2 из 3';
      textEl.textContent = 'Ответ выбирается по номерам: нажмите числа слева у вариантов, где ударение выделено верно.';

      clearHighlights();
      const nums = grid.querySelectorAll('.t4-num');
      nums.forEach(btn => btn.classList.add('t4-tut-highlight', 't4-tut-blink'));
      const anchor = nums[0] || correctLetter;
      requestAnimationFrame(() => positionOverlayToElement(anchor));
    }

    if (step === 3) {
      titleEl.textContent = 'Шаг 3 из 3';
      textEl.textContent = 'Готово. Нажмите «Понятно», чтобы больше не показывать обучение.';
      clearHighlights();
      doneBtn.style.display = 'inline-block';
      const anchor = document.getElementById('t4-check-' + taskId) || correctLetter;
      requestAnimationFrame(() => positionOverlayToElement(anchor));
    }
  }

  function goNext(n) {
    step = n;
    renderStep();
  }

  renderStep();

  function onGridClick(e) {
    if (step === 1) {
      const ch = e.target.closest('.t4-ch');
      if (!ch) return;
      if (correctLetter.classList.contains('marked')) goNext(2);
      return;
    }

    if (step === 2) {
      const numBtn = e.target.closest('.t4-num');
      if (!numBtn) return;
      if (grid.querySelectorAll('.t4-num.selected').length > 0) goNext(3);
    }
  }

  grid.addEventListener('click', onGridClick);
}

function renderResult(taskId, data, resultEl) {
  data.items.forEach(item => {
    const card   = document.getElementById('t4-item-' + taskId + '-' + item.item_index);
    const wordEl = document.getElementById('t4-word-' + taskId + '-' + item.item_index);

    card.classList.remove('selected');
    if      (item.is_correct && item.user_selected)  card.classList.add('result-correct');
    else if (item.is_correct && !item.user_selected) card.classList.add('result-missed');
    else if (!item.is_correct && item.user_selected) card.classList.add('result-wrong');
    else                                              card.classList.add('result-neutral');

    wordEl.innerHTML = renderAnswerWord(item.word, item.correct_stress_index);
  });

  const allOk      = data.all_correct;
  const correctStr = data.correct_indices.join(', ');

  let html = `<div class="task-card task17-card" style="padding:16px 20px;">
    <div class="task-meta" style="margin-bottom:14px;">
      <span class="task-meta__number" style="color:${allOk ? 'var(--brand)' : '#D69295'};">
        ${allOk ? '✓ Верно' : '✗ Есть ошибки'}
      </span>
      <span class="task-meta__source">Правильный ответ: <strong>${correctStr}</strong></span>
    </div>
    <div class="t4-result-block">`;

  data.items.forEach(item => {
    const color = item.item_ok ? 'var(--brand)' : '#D69295';
    const icon  = item.item_ok ? '✓' : '✗';
    const ci    = item.correct_stress_index;
    const correctDisplay =
      escHtml(item.word.slice(0, ci)) +
      `<strong>${item.word[ci].toUpperCase()}</strong>` +
      escHtml(item.word.slice(ci + 1));

    let desc = item.is_correct
      ? `${correctDisplay} — ударение верное`
      : `${escHtml(item.word_stressed)} — неверное, правильно: ${correctDisplay}`;
    if (item.hint)
      desc += ` <span style="color:var(--text-secondary);font-size:13px;">— ${escHtml(item.hint)}</span>`;

    let ruleHtml = '';
    if (item.category_rule) {
      const exc = item.is_exception
        ? '<span style="background:rgba(245,158,11,.15);color:#f59e0b;border-radius:3px;padding:1px 5px;font-size:11px;margin-left:4px;">исключение</span>'
        : '';
      ruleHtml = `<div class="t4-rule">${escHtml(item.category_name)}${exc}: ${escHtml(item.category_rule)}</div>`;
    }

    html += `<div class="t4-result-row">
      <span class="t4-result-icon" style="color:${color};">${icon}</span>
      <div><span style="font-size:15px;">${item.item_index}. </span>${desc}${ruleHtml}</div>
    </div>`;
  });

  html += `</div></div>`;
  resultEl.innerHTML = html;
  resultEl.style.display = 'block';
  resultEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

async function loadAndInsertTask(taskId, targetEl) {
  const res = await fetch('/api/task4/tasks/' + taskId + '/play');
  if (!res.ok) return;
  const task = await res.json();
  targetEl.innerHTML = renderPlayCard(taskId, task);
  initPlayCard(taskId);
}

async function loadFeed() {
  const feed = document.getElementById('tasks-feed');
  let tasks;
  try {
    const res = await fetch('/api/task4/tasks');
    if (!res.ok) throw new Error();
    tasks = await res.json();
  } catch {
    feed.innerHTML = '<p style="color:#D69295;margin:0;">Не удалось загрузить задания.</p>';
    return;
  }
  if (!Array.isArray(tasks) || !tasks.length) {
    feed.innerHTML =
      '<p style="color:var(--text-secondary);margin:0;">Пока нет заданий. Сгенерируйте вариант или добавьте задания в админке.</p>';
    return;
  }

  const plays = await Promise.all(
    tasks.map(t => fetch('/api/task4/tasks/' + t.id + '/play').then(r => r.ok ? r.json() : null))
  );

  const blocks = [];
  for (let i = 0; i < tasks.length; i++) {
    const t = tasks[i];
    const play = plays[i];
    if (!play) continue;
    blocks.push('<div class="task9-feed-item" id="task4-feed-' + t.id + '">' + renderPlayCard(t.id, play) + '</div>');
  }

  if (!blocks.length) {
    feed.innerHTML = '<p style="color:var(--text-secondary);margin:0;">Не удалось загрузить задания.</p>';
    return;
  }

  feed.innerHTML = blocks.join('');
  for (let i = 0; i < tasks.length; i++) {
    if (plays[i]) initPlayCard(tasks[i].id);
  }

  const firstIdx = plays.findIndex(p => p);
  if (firstIdx >= 0) {
    const firstTaskId = tasks[firstIdx].id;
    const firstPlay = plays[firstIdx];
    window.__t4FirstTaskForList = { id: firstTaskId, task: firstPlay };
    maybeStartTutorialForTask(firstTaskId, firstPlay);
  }
}

// Ручной запуск обучения на странице списка
window.t4ShowTutorialList = function () {
  const ref = window.__t4FirstTaskForList;
  if (ref && ref.id && ref.task) {
    startTutorialForTask(ref.id, ref.task);
  }
};

document.getElementById('btn-generate-task4').addEventListener('click', async () => {
  const btn = document.getElementById('btn-generate-task4');
  btn.disabled = true;
  btn.textContent = 'Генерируем...';
  try {
    const correctCounts = Array.from(document.querySelectorAll('.task4-count-checkbox:checked'))
      .map(el => el.value);
    if (!correctCounts.length) { alert('Выберите количество правильных слов'); return; }
    const body = {
      correct_counts: correctCounts,
      tasks_count: +document.getElementById('task4-tasks-count').value || 1,
    };
    const res = await fetch('/api/task4/generate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const data = await res.json();
    if (data.error) { alert(data.error); return; }

    const ids = Array.isArray(data.ids) ? data.ids : [data.id];
    const feed = document.getElementById('tasks-feed');

    for (const id of ids) {
      if (document.getElementById('task4-feed-' + id)) continue;
      const wrapper = document.createElement('div');
      wrapper.className = 'task9-feed-item';
      wrapper.id = 'task4-feed-' + id;
      feed.prepend(wrapper);
      await loadAndInsertTask(id, wrapper);
    }

    const firstId = ids[0];
    const firstEl = document.getElementById('task4-feed-' + firstId);
    if (firstEl) firstEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
  } finally {
    btn.disabled = false;
    btn.textContent = 'Сгенерировать';
  }
});

document.querySelectorAll('.task4-count-checkbox').forEach(cb => {
  cb.addEventListener('change', () => {
    if (!cb.checked) return;
    document.querySelectorAll('.task4-count-checkbox').forEach(other => {
      if (other !== cb) other.checked = false;
    });
  });
});

loadFeed();
</script>

<button
  type="button"
  class="t4-help-fab"
  aria-label="Показать обучение"
  title="Показать обучение"
  onclick="window.t4ShowTutorialList && window.t4ShowTutorialList()"
>?</button>
