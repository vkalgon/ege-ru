// ── Утилиты ──────────────────────────────────────────────────────────

function escHtml(s) {
  return String(s)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

// Безопасная вставка с разрешёнными <em>
function safeHtml(s) {
  return escHtml(s).replace(/&lt;em&gt;/g, '<em>').replace(/&lt;\/em&gt;/g, '</em>');
}

const FAV_ICON = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>`;

// ── Избранное ─────────────────────────────────────────────────────────

let favorites = new Set();

async function loadFavorites() {
  try {
    const data = await fetch('/api/task5/paronym-favorites').then(r => r.json());
    favorites = new Set(data.favorites || []);
    updateFavButtons();
  } catch (_) {}
}

function updateFavButtons() {
  document.querySelectorAll('.t5th-fav-btn').forEach(btn => {
    const saved = favorites.has(btn.dataset.id);
    btn.classList.toggle('is-saved', saved);
    btn.title = saved ? 'Убрать из слабых мест' : 'Добавить в слабые места';
  });
}

async function toggleFavorite(id, btn) {
  btn.disabled = true;
  try {
    const data = await fetch(`/api/task5/paronym-favorites/${encodeURIComponent(id)}`, { method: 'POST' }).then(r => r.json());
    if (data.saved) favorites.add(id); else favorites.delete(id);
    btn.classList.toggle('is-saved', data.saved);
    btn.title = data.saved ? 'Убрать из слабых мест' : 'Добавить в слабые места';
  } catch (_) {}
  btn.disabled = false;
}

// ── Рендер сетки пар ─────────────────────────────────────────────────

let currentFilter = '';

function matchesPair(pair, q) {
  if (!q) return true;
  return pair.words.some(w => w.word.toLowerCase().includes(q));
}

function renderGrid() {
  const q = currentFilter;
  const grid = document.getElementById('t5th-grid');
  const noResults = document.getElementById('t5th-no-results');
  grid.innerHTML = '';

  let visibleCount = 0;
  let currentLetter = null;
  let letterSepEl = null;
  let letterCount = 0;

  for (const pair of PARONYMS_THEORY) {
    if (!matchesPair(pair, q)) continue;
    visibleCount++;

    // Разделитель буквы — показываем только если под ней есть совпадения
    if (pair.letter && pair.letter !== currentLetter) {
      currentLetter = pair.letter;
      letterSepEl = document.createElement('div');
      letterSepEl.className = 't5th-letter-sep';
      letterSepEl.textContent = currentLetter;
      grid.appendChild(letterSepEl);
      letterCount = 0;
    }
    if (letterSepEl) letterCount++;

    const wordsHtml = pair.words.map((w, i) => {
      let name = escHtml(w.word);
      if (q) {
        // подсветить совпадение
        const idx = w.word.toLowerCase().indexOf(q);
        if (idx !== -1) {
          name = escHtml(w.word.slice(0, idx))
            + `<mark class="t5th-hl">${escHtml(w.word.slice(idx, idx + q.length))}</mark>`
            + escHtml(w.word.slice(idx + q.length));
        }
      }
      return (i > 0 ? `<span class="t5th-pill-sep">/</span>` : '') + name;
    }).join('');

    const row = document.createElement('div');
    row.className = 't5th-pill-row';

    const pillBtn = document.createElement('button');
    pillBtn.className = 't5th-pill';
    pillBtn.innerHTML = `<div class="t5th-pill-words">${wordsHtml}</div>`;
    pillBtn.addEventListener('click', () => openModal(pair.id));

    const favBtn = document.createElement('button');
    favBtn.className = 't5th-fav-btn';
    favBtn.dataset.id = pair.id;
    favBtn.innerHTML = FAV_ICON;
    favBtn.title = 'Добавить в слабые места';
    favBtn.addEventListener('click', e => { e.stopPropagation(); toggleFavorite(pair.id, favBtn); });

    row.appendChild(pillBtn);
    row.appendChild(favBtn);
    grid.appendChild(row);
  }

  noResults.hidden = visibleCount > 0;
  updateFavButtons();
}

// ── Рендер карточки слова ────────────────────────────────────────────

function renderWordCard(wordData) {
  const defsHtml = wordData.definitions.map((def, i) => {
    const numHtml = wordData.definitions.length > 1
      ? `<span class="t5th-def-num">${i + 1}</span>`
      : '';
    const labelHtml = def.label
      ? ` <span class="t5th-def-label">(${escHtml(def.label)})</span>`
      : '';

    const synsHtml = def.synonyms && def.synonyms.length
      ? `<div class="t5th-syn-label">Синонимы</div>
         <div class="t5th-synonyms">${def.synonyms.map(s => `<span class="t5th-syn-chip">${escHtml(s)}</span>`).join('')}</div>`
      : '';

    const exHtml = def.examples && def.examples.length
      ? `<div class="t5th-examples">
           <div class="t5th-ex-label">Примеры употребления</div>
           ${def.examples.map(e => `<div class="t5th-ex-item">${safeHtml(e)}</div>`).join('')}
         </div>`
      : '';

    return `<div class="t5th-def-item">
      <div>${numHtml}<span class="t5th-def-text">${safeHtml(def.text)}</span>${labelHtml}</div>
      ${synsHtml}
      ${exHtml}
    </div>`;
  }).join('');

  const grammarHtml = wordData.grammar
    ? `<span class="t5th-word-grammar">${escHtml(wordData.grammar)}</span>`
    : '';
  return `<div class="t5th-word-card">
    <div class="t5th-word-heading">${escHtml(wordData.word)}${grammarHtml}</div>
    <div class="t5th-def-list">${defsHtml}</div>
  </div>`;
}

// ── Открыть/закрыть модалку ──────────────────────────────────────────

function openModal(id) {
  const pair = PARONYMS_THEORY.find(p => p.id === id);
  if (!pair) return;

  const overlay = document.getElementById('t5th-overlay');
  const body    = document.getElementById('t5th-modal-body');

  const n = pair.words.length;
  const gridClass = (n === 3 || n >= 5) ? 't5th-words-grid t5th-words-grid--3' : 't5th-words-grid';
  const wordsGridHtml = pair.words.map(renderWordCard).join('');
  const noteHtml = pair.note
    ? `<div class="t5th-note"><strong>⚠ Внимание.</strong> ${escHtml(pair.note)}</div>`
    : '';

  body.innerHTML = `
    <p class="t5th-modal-title">Паронимы</p>
    <div class="${gridClass}">${wordsGridHtml}</div>
    ${noteHtml}`;

  overlay.removeAttribute('hidden');
  document.body.style.overflow = 'hidden';
  document.getElementById('t5th-close').focus();
}

function closeModal() {
  const overlay = document.getElementById('t5th-overlay');
  overlay.setAttribute('hidden', '');
  document.body.style.overflow = '';
}

// ── Инициализация ────────────────────────────────────────────────────

document.getElementById('t5th-close').addEventListener('click', closeModal);
document.getElementById('t5th-overlay').addEventListener('click', e => {
  if (e.target === e.currentTarget) closeModal();
});
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closeModal();
});

// ── Поиск ────────────────────────────────────────────────────────────

const searchInput = document.getElementById('t5th-search');
const searchClear = document.getElementById('t5th-search-clear');

searchInput.addEventListener('input', () => {
  currentFilter = searchInput.value.trim().toLowerCase();
  searchClear.hidden = !currentFilter;
  renderGrid();
});

searchClear.addEventListener('click', () => {
  searchInput.value = '';
  currentFilter = '';
  searchClear.hidden = true;
  searchInput.focus();
  renderGrid();
});

renderGrid();
loadFavorites();
</script>
