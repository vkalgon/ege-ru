<!-- ── Main variant initializer ──────────────────────────── -->
<script>
(async () => {
  const variantId   = document.getElementById('variantPlayPage').dataset.id;
  const listEl      = document.getElementById('variantList');
  const fillEl      = document.getElementById('vProgressFill');
  const textEl      = document.getElementById('vProgressText');
  const storageKey  = 'variant_done_' + variantId;

  let tasks  = [];
  let doneSet = new Set(JSON.parse(localStorage.getItem(storageKey) || '[]'));

  // ── Wait for React/Babel to initialise ──────────────────
  await new Promise(resolve => {
    if (window._VL_REACT_READY) { resolve(); return; }
    const iv = setInterval(() => { if (window._VL_REACT_READY) { clearInterval(iv); resolve(); } }, 30);
    setTimeout(() => { clearInterval(iv); resolve(); }, 4000);
  });

  // ── Fetch variant data ───────────────────────────────────
  let data;
  try {
    data = await fetch('/api/variant/' + variantId).then(r => r.json());
    if (data.error) throw new Error(data.error);
    tasks = data.tasks;
  } catch(e) {
    listEl.innerHTML = `<p class="vplay-loading" style="color:#D69295">Ошибка: ${e.message}</p>`;
    return;
  }

  // ── Progress ─────────────────────────────────────────────
  function updateProgress() {
    const done  = tasks.filter(t => doneSet.has(t.index)).length;
    const total = tasks.length;
    fillEl.style.width = total ? Math.round(done/total*100)+'%' : '0%';
    textEl.textContent = done + ' / ' + total;
  }
  function saveDone() {
    localStorage.setItem(storageKey, JSON.stringify([...doneSet]));
    updateProgress();
  }

  // ── Render task sections ─────────────────────────────────
  listEl.innerHTML = '';

  for (const task of tasks) {
    const isDone = doneSet.has(task.index);

    // Section wrapper
    const section = document.createElement('div');
    section.className = 'vplay-section';
    section.dataset.index = task.index;

    // Divider (not before first)
    if (task.index > 1) {
      const hr = document.createElement('hr');
      hr.className = 'vplay-divider';
      section.appendChild(hr);
    }

    // Label row
    const label = document.createElement('div');
    label.className = 'vplay-label' + (isDone ? ' vplay-label--done' : '');
    label.innerHTML =
      `<span class="vplay-label__index">${task.index}</span>` +
      `<span class="vplay-label__text">Задание ${task.num} — ${task.label}</span>` +
      (isDone ? '<span class="vplay-label__done-mark">✓ выполнено</span>' : '');

    // "Done" toggle on label click
    label.style.cursor = 'pointer';
    label.title = 'Отметить как выполненное';
    function refreshLabel(t) {
      const done = doneSet.has(t.index);
      label.className = 'vplay-label' + (done ? ' vplay-label--done' : '');
      label.innerHTML =
        `<span class="vplay-label__index">${t.index}</span>` +
        `<span class="vplay-label__text">Задание ${t.num} — ${t.label}</span>` +
        (done ? '<span class="vplay-label__done-mark">✓ выполнено</span>' : '');
    }
    label.addEventListener('click', () => {
      if (doneSet.has(task.index)) doneSet.delete(task.index);
      else                          doneSet.add(task.index);
      saveDone();
      refreshLabel(task);
    });

    // Task slot
    const slot = document.createElement('div');
    slot.className = 'vplay-slot';

    section.appendChild(label);
    section.appendChild(slot);
    listEl.appendChild(section);

    // Load the task
    const loader = window._VL[task.type];
    if (loader) {
      await loader(slot, task.taskId);
    } else {
      slot.innerHTML = `<a href="${task.url}" class="btn" target="_blank" style="margin-top:4px;">Открыть задание →</a>`;
    }
  }

  updateProgress();

  // ── Reset ────────────────────────────────────────────────
  document.getElementById('vResetBtn').addEventListener('click', () => {
    if (!confirm('Сбросить отметки о выполнении?')) return;
    doneSet.clear(); saveDone();
    // Update all labels
    listEl.querySelectorAll('.vplay-label').forEach(label => {
      const idx = +label.closest('.vplay-section').dataset.index;
      const t = tasks.find(t => t.index === idx);
      if (!t) return;
      label.className = 'vplay-label';
      label.innerHTML =
        `<span class="vplay-label__index">${t.index}</span>` +
        `<span class="vplay-label__text">Задание ${t.num} — ${t.label}</span>`;
    });
  });
})();
</script>

<!-- ── Text-analysis toolbar for tasks 17, 18, 19 ────────── -->
<script>
(function() {
  if (typeof TextSelectionToolbar === 'undefined') return;

  /* ── Undo (Ctrl+Z) ──────────────────────────────────────── */
  const _undoStack = [];
  function _saveUndo(editor) {
    _undoStack.push({ editor, html: editor.innerHTML });
    if (_undoStack.length > 50) _undoStack.shift();
  }
  document.addEventListener('keydown', function(e) {
    if ((e.ctrlKey || e.metaKey) && e.key === 'z' && !e.shiftKey) {
      const inEditor = document.activeElement && document.activeElement.closest('.task17-text-editable');
      if (inEditor && _undoStack.length) { e.preventDefault(); const { editor, html } = _undoStack.pop(); editor.innerHTML = html; }
    }
  });

  /* ── Расширение до границ слов ──────────────────────────── */
  function _expandToWords(range) {
    const r = range.cloneRange();
    if (r.startContainer.nodeType === Node.TEXT_NODE) {
      const txt = r.startContainer.textContent; let o = r.startOffset;
      while (o > 0 && txt[o - 1] !== ' ') o--;
      r.setStart(r.startContainer, o);
    }
    if (r.endContainer.nodeType === Node.TEXT_NODE) {
      const txt = r.endContainer.textContent; let o = r.endOffset;
      while (o < txt.length && txt[o] !== ' ') o++;
      r.setEnd(r.endContainer, o);
    }
    while (true) {
      if (r.startContainer.nodeType === Node.TEXT_NODE && r.startOffset === 0) {
        const prev = r.startContainer.previousSibling;
        if (prev && prev.nodeType === Node.TEXT_NODE) { const t = prev.textContent; const sp = t.lastIndexOf(' '); r.setStart(prev, sp >= 0 ? sp + 1 : 0); continue; }
      }
      break;
    }
    while (true) {
      if (r.endContainer.nodeType === Node.TEXT_NODE && r.endOffset >= r.endContainer.textContent.length) {
        const next = r.endContainer.nextSibling;
        if (next && next.nodeType === Node.TEXT_NODE) { const t = next.textContent; const sp = t.indexOf(' '); r.setEnd(next, sp >= 0 ? sp : t.length); continue; }
      }
      break;
    }
    return r;
  }

  function _findEditor(el) {
    while (el && !el.classList.contains('task17-text-editable')) el = el.parentElement;
    return el || null;
  }

  /* ── Bracket handles (task 19) ──────────────────────────── */
  let _bhCounter = 0;
  function _createHandle(char, pairId, type, bhClass) {
    const span = document.createElement('span');
    span.className = 'bracket-handle ' + bhClass;
    span.dataset.pairId = pairId;
    span.dataset.type   = type;
    span.contentEditable = 'false';
    span.draggable = true;
    span.textContent = char;
    span.title = 'Перетащите чтобы переместить • Клик — удалить пару';
    return span;
  }

  /* ── Применение разметки ────────────────────────────────── */
  window.applySpanClass = function(className) {
    const sel = window.getSelection();
    if (!sel || !sel.rangeCount || !sel.toString().trim()) return;
    let range = sel.getRangeAt(0);
    const anchor = range.commonAncestorContainer.nodeType === 3
      ? range.commonAncestorContainer.parentElement
      : range.commonAncestorContainer;
    const editor = _findEditor(anchor);
    if (!editor) return;
    _saveUndo(editor);
    range = _expandToWords(range);

    if (className === 'bracket-main' || className === 'bracket-sub') {
      const pairId  = 'bh' + (++_bhCounter);
      const bhClass = className === 'bracket-main' ? 'bh-main' : 'bh-sub';
      const chars   = className === 'bracket-main' ? ['[', ']'] : ['(', ')'];
      const open  = _createHandle(chars[0], pairId, 'open',  bhClass);
      const close = _createHandle(chars[1], pairId, 'close', bhClass);
      const startNode = range.startContainer, startOffset = range.startOffset;
      const endRange = range.cloneRange(); endRange.collapse(false); endRange.insertNode(close);
      const openRange = document.createRange(); openRange.setStart(startNode, startOffset); openRange.collapse(true); openRange.insertNode(open);
    } else {
      const span = document.createElement('span');
      span.className = className;
      try { range.surroundContents(span); }
      catch (_) { const c = range.extractContents(); span.appendChild(c); range.insertNode(span); }
    }
    sel.removeAllRanges();
    if (editor.contentEditable === 'true') editor.focus();
  };

  /* ── Удаление разметки ──────────────────────────────────── */
  const _SPAN_CLASSES = ['span-subject','span-predicate','span-participle','span-gerund','span-main-word'];
  window.removeMark = function() {
    const sel = window.getSelection();
    if (!sel || !sel.rangeCount) return;
    let el = sel.getRangeAt(0).commonAncestorContainer;
    if (el.nodeType === 3) el = el.parentElement;
    const handle = el.closest && el.closest('.bracket-handle');
    if (handle) {
      const editor = _findEditor(handle);
      if (editor) { _saveUndo(editor); editor.querySelectorAll(`.bracket-handle[data-pair-id="${handle.dataset.pairId}"]`).forEach(h => h.remove()); }
      sel.removeAllRanges();
      return;
    }
    while (el) {
      if (el.classList && _SPAN_CLASSES.some(c => el.classList.contains(c))) {
        const editor = _findEditor(el);
        if (editor) _saveUndo(editor);
        const p = el.parentNode;
        while (el.firstChild) p.insertBefore(el.firstChild, el);
        p.removeChild(el);
        sel.removeAllRanges();
        return;
      }
      if (el.classList && el.classList.contains('task17-text-editable')) break;
      el = el.parentElement;
    }
  };

  /* ── Drag-and-drop скобок (task 19) ─────────────────────── */
  function _initDragDrop(editor) {
    let dragging = null, dropMarker = null;
    function getMarker() {
      if (!dropMarker) {
        dropMarker = document.createElement('span');
        dropMarker.className = 'bh-drop-marker';
        dropMarker.style.cssText = 'display:inline-block;width:2px;height:1.2em;background:var(--brand);vertical-align:middle;border-radius:1px;margin:0 1px;animation:bhBlink 0.6s infinite;';
      }
      return dropMarker;
    }
    function getRangeAt(x, y) {
      const ex = editor.querySelector('.bh-drop-marker'); if (ex) ex.remove();
      if (document.caretRangeFromPoint) return document.caretRangeFromPoint(x, y);
      if (document.caretPositionFromPoint) { const p = document.caretPositionFromPoint(x, y); if (p) { const r = document.createRange(); r.setStart(p.offsetNode, p.offset); r.collapse(true); return r; } }
      return null;
    }
    editor.addEventListener('dragstart', function(e) {
      if (!e.target.classList.contains('bracket-handle')) return;
      dragging = e.target; dragging.dataset.dragging = 'true';
      e.dataTransfer.effectAllowed = 'move'; e.dataTransfer.setData('text/plain', 'bh');
    });
    editor.addEventListener('dragend', function() {
      if (dragging) { dragging.dataset.dragging = 'false'; dragging = null; }
      getMarker().remove(); editor.classList.remove('bh-drag-over');
    });
    editor.addEventListener('dragover', function(e) {
      if (!dragging) return; e.preventDefault(); e.dataTransfer.dropEffect = 'move';
      editor.classList.add('bh-drag-over');
      const r = getRangeAt(e.clientX, e.clientY); if (r) r.insertNode(getMarker());
    });
    editor.addEventListener('dragleave', function(e) {
      if (!editor.contains(e.relatedTarget)) { editor.classList.remove('bh-drag-over'); getMarker().remove(); }
    });
    editor.addEventListener('drop', function(e) {
      if (!dragging) return; e.preventDefault(); editor.classList.remove('bh-drag-over');
      const m = getMarker();
      if (m.parentNode) { m.parentNode.insertBefore(dragging, m); m.remove(); }
      dragging.dataset.dragging = 'false'; dragging = null;
      window.getSelection().removeAllRanges();
    });
    editor.addEventListener('click', function(e) {
      const handle = e.target.closest && e.target.closest('.bracket-handle');
      if (!handle) return;
      _saveUndo(editor);
      editor.querySelectorAll(`.bracket-handle[data-pair-id="${handle.dataset.pairId}"]`).forEach(h => h.remove());
    });
  }

  /* ── Инициализация тулбаров ─────────────────────────────── */
  const onBtn = function(btn) { if (btn.class) window.applySpanClass(btn.class); };
  const onRm  = function()    { window.removeMark(); };

  // Toolbar task 17/18 — причастный / деепричастный оборот
  const t17 = new TextSelectionToolbar({
    containerId: 'variant-toolbar-17',
    editorSelector: '.task17-text-editable:not(.task19-text-editable)',
    ignoreSelectors: ['.task17-digit'],
    defaultButtons: true,
    onButtonClick: onBtn,
    onRemoveClick: onRm
  });
  t17.setupAutoShow();

  // Toolbar task 19 — скобки + подлежащее/сказуемое
  const t19 = new TextSelectionToolbar({
    containerId: 'variant-toolbar-19',
    editorSelector: '.task19-text-editable',
    ignoreSelectors: ['.task17-digit', '.bracket-handle'],
    defaultButtons: false,
    customButtons: [
      { class:'bracket-main',  icon:'<svg width="28" height="20" viewBox="0 0 28 20" xmlns="http://www.w3.org/2000/svg"><text x="2" y="15" font-size="15" font-weight="bold" fill="#4a9eff" font-family="monospace">[ ]</text></svg>', title:'Главное предложение' },
      { class:'bracket-sub',   icon:'<svg width="28" height="20" viewBox="0 0 28 20" xmlns="http://www.w3.org/2000/svg"><text x="2" y="15" font-size="15" font-weight="bold" fill="#ff8c42" font-family="monospace">( )</text></svg>', title:'Придаточное предложение' },
      { class:'span-subject',  icon:'<svg width="24" height="8" viewBox="0 0 24 8" xmlns="http://www.w3.org/2000/svg"><line x1="2" y1="6" x2="22" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>', title:'Подлежащее' },
      { class:'span-predicate',icon:'<svg width="24" height="8" viewBox="0 0 24 8" xmlns="http://www.w3.org/2000/svg"><line x1="2" y1="4" x2="22" y2="4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="2" y1="7" x2="22" y2="7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>', title:'Сказуемое' }
    ],
    onButtonClick: onBtn,
    onRemoveClick: onRm
  });
  t19.setupAutoShow();

  // Подключаем drag-drop к task19-текстам по мере их появления
  const _t19Init = setInterval(function() {
    document.querySelectorAll('.task19-text-editable:not([data-dnd-init])').forEach(function(editor) {
      editor.dataset.dndInit = '1';
      _initDragDrop(editor);
    });
  }, 300);
  setTimeout(function() { clearInterval(_t19Init); }, 15000);
})();
</script>
