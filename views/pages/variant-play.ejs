<div id="variantPlayPage" data-id="<%= variantId %>">
  <div class="vplay-header">
    <h1 class="vplay-title">Вариант <span class="vplay-title__id">#<%= variantId %></span></h1>
    <div class="vplay-progress-wrap">
      <div class="vplay-progress-bar"><div class="vplay-progress-fill" id="vProgressFill"></div></div>
      <span class="vplay-progress-text" id="vProgressText">0 / 0</span>
    </div>
  </div>
  <div id="variantList"><p class="vplay-loading">Загрузка…</p></div>
  <div class="vplay-footer">
    <a href="/variant" class="btn">Создать новый вариант</a>
    <button class="btn btn-secondary" id="vResetBtn">Сбросить прогресс</button>
  </div>
</div>

<style>
/* ── Layout ─────────────────────────────────────────────── */
#variantPlayPage { max-width: 780px; margin: 0 auto; padding: 32px 16px; display: flex; flex-direction: column; gap: 32px; }

.vplay-header { display: flex; flex-direction: column; gap: 14px; }
.vplay-title  { font-size: 26px; font-weight: 700; color: var(--text-primary); margin: 0; }
.vplay-title__id { color: var(--brand); }

.vplay-progress-wrap { display: flex; align-items: center; gap: 12px; }
.vplay-progress-bar  { flex: 1; height: 5px; border-radius: 3px; background: var(--bg-tertiary); overflow: hidden; }
.vplay-progress-fill { height: 100%; background: var(--brand); border-radius: 3px; transition: width .3s ease; width: 0%; }
.vplay-progress-text { font-size: 13px; font-weight: 600; color: var(--text-secondary); white-space: nowrap; }

.vplay-loading { color: var(--text-secondary); padding: 32px 0; text-align: center; }

/* ── Task sections ──────────────────────────────────────── */
.vplay-section { display: flex; flex-direction: column; gap: 10px; }
.vplay-divider  { border: none; border-top: 1px solid var(--glass-border); margin: 8px 0; }

.vplay-label {
  display: flex; align-items: center; gap: 10px;
  font-size: 13px; font-weight: 600;
  color: var(--text-secondary); text-transform: uppercase; letter-spacing: .05em;
}
.vplay-label__index {
  width: 24px; height: 24px; border-radius: 50%;
  background: var(--bg-tertiary); border: 1px solid var(--glass-border);
  color: var(--text-primary); font-size: 12px; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.vplay-label--done .vplay-label__index { background: var(--brand-muted); border-color: var(--brand); color: var(--brand); }
.vplay-label__done-mark { color: var(--brand); font-size: 14px; margin-left: auto; }
.vplay-label__text { color: var(--brand); }

.vplay-slot { min-height: 40px; }

/* ── Footer ─────────────────────────────────────────────── */
.vplay-footer { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; padding-top: 16px; border-top: 1px solid var(--glass-border); }

/* ── Task 17 digit styles (needed inline) ───────────────── */
.task17-digit { cursor: pointer; padding: 1px 4px; margin: 0 1px; border-radius: 4px; transition: all .2s; display: inline-block; position: relative; }
.task17-digit:hover:not(.selected):not(.correct-selected):not(.extra-selected):not(.correct) { background-color: var(--brand-muted); }
.task17-digit.selected       { background-color: rgba(164,190,226,.2); color: var(--brand); outline: 1.5px solid var(--brand-dim); outline-offset: -1px; }
.task17-digit.correct        { background-color: transparent !important; color: #A4E2D0 !important; outline: 1.5px solid #A4E2D0 !important; outline-offset: -1px; }
.task17-digit.correct-selected { background-color: rgba(164,226,208,0.12) !important; color: #A4E2D0 !important; outline: 1.5px solid #A4E2D0 !important; outline-offset: -1px; font-weight: bold; }
.task17-digit.extra-selected { background-color: #D69295 !important; color: #0f1117 !important; font-weight: bold; }
/* Task19 bracket handles */
.bracket-handle { display:inline-block; font-weight:bold; font-size:1.15em; line-height:1; padding:0 2px; border-radius:3px; cursor:grab; user-select:none; transition:background .15s, transform .1s; }
.bracket-handle:hover { transform:scale(1.2); }
.bracket-handle:active { cursor:grabbing; }
.bracket-handle.bh-main { color:#4a9eff; }
.bracket-handle.bh-main:hover { background:rgba(74,158,255,.18); }
.bracket-handle.bh-sub  { color:#ff8c42; }
.bracket-handle.bh-sub:hover  { background:rgba(255,140,66,.18); }
.bracket-handle[data-dragging="true"] { opacity:.3; }
.task17-text-editable.bh-drag-over { outline:2px dashed var(--glass-border); }
@keyframes bhBlink { 0%,100%{opacity:1} 50%{opacity:.2} }
/* Task18 word cards */
.task18-word-card { padding:10px 14px; border-radius:8px; border:1px solid var(--glass-border); font-size:.9rem; margin-bottom:8px; }
.task18-word-card.ok  { border-color:rgba(164,226,208,.5); background:rgba(164,226,208,.07); }
.task18-word-card.err { border-color:rgba(214,146,149,.5); background:rgba(214,146,149,.07); }
.task18-word-card__phrase { font-weight:700; font-size:1rem; }
.task18-word-card__type   { font-size:.8rem; color:var(--text-secondary); margin-left:6px; }
.task18-word-card__rule   { margin-top:4px; color:var(--text-secondary); font-size:.88rem; }
/* Task5/7 styles */
.t5-sentences-wrap,.t7-phrases-wrap { display:flex; flex-direction:column; gap:12px; }
.t5-sentence-item,.t7-phrase-item { display:flex; gap:14px; align-items:flex-start; background:var(--bg-secondary); border:1px solid var(--glass-border); border-radius:8px; padding:14px 16px; font-size:15px; line-height:1.6; transition:border-color .25s,background .25s; }
.t5-sentence-item.state-error,.t7-phrase-item.state-error { border-color:#D69295; }
.t5-sentence-item.state-ok,.t7-phrase-item.state-ok       { border-color:var(--brand); }
.t5-sentence-num,.t7-phrase-num { flex-shrink:0; width:28px; height:28px; border-radius:50%; background:var(--glass-border); color:var(--text-secondary); font-size:13px; font-weight:700; display:flex; align-items:center; justify-content:center; }
.t5-sentence-item.state-error .t5-sentence-num,.t7-phrase-item.state-error .t7-phrase-num { background:rgba(214,146,149,.2); color:#D69295; }
.t5-sentence-item.state-ok    .t5-sentence-num,.t7-phrase-item.state-ok    .t7-phrase-num { background:var(--brand-muted); color:var(--brand); }
.t5-sentence-text,.t7-phrase-text { flex:1; }
.t5-hl,.t7-hl { font-weight:700; font-variant:small-caps; letter-spacing:.04em; text-decoration:underline dotted; text-underline-offset:3px; }
/* Task4 styles */
.t4-items { display:flex; flex-direction:column; gap:10px; }
.t4-item  { display:flex; align-items:center; gap:14px; padding:12px 18px; background:var(--bg-secondary); border:1px solid var(--glass-border); border-radius:8px; transition:border-color .2s,background .2s; }
.t4-item.selected        { border-color:var(--brand); background:var(--brand-muted); }
.t4-item.result-correct  { border-color:var(--brand); background:var(--brand-muted); }
.t4-item.result-missed   { border-color:#f59e0b; background:rgba(245,158,11,.06); }
.t4-item.result-wrong    { border-color:#D69295; background:rgba(214,146,149,.08); }
.t4-item.result-neutral  { border-color:var(--glass-border); opacity:.65; }
.t4-num  { width:32px; height:32px; border-radius:6px; border:1px solid var(--glass-border); background:none; cursor:pointer; font-size:14px; font-weight:700; color:var(--text-secondary); display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:border-color .2s,color .2s,background .2s; }
.t4-num:hover:not(:disabled) { border-color:var(--brand); color:var(--brand); }
.t4-num.selected { border-color:var(--brand); color:var(--brand); background:var(--brand-muted); }
.t4-num:disabled { cursor:default; }
.t4-word { font-size:20px; cursor:default; }
.t4-ch   { cursor:pointer; border-radius:3px; }
.t4-ch:hover { background:rgba(255,255,255,.08); }
.t4-ch.marked  { background:rgba(245,158,11,.35); }
.t4-ch.locked  { cursor:default; }
.t4-ch.locked:hover { background:none; }
.t4-ch.answer-ch { color:var(--brand); font-weight:700; }
.t4-result-block { display:flex; flex-direction:column; gap:10px; }
.t4-result-row   { display:flex; align-items:flex-start; gap:10px; font-size:14px; line-height:1.5; }
.t4-result-icon  { font-weight:700; width:18px; flex-shrink:0; padding-top:1px; }
.t4-rule { margin-top:3px; font-size:12px; color:var(--text-secondary); }
</style>

<!-- ── Shared task JS ─────────────────────────────────────── -->
<script src="/js/task-card-shell.js"></script>
<script src="/js/task-play-card.js"></script>
<script src="/js/text-selection-toolbar.js"></script>

<!-- ── Plain JS loaders (tasks 4, 5, 7, 9–12) ──────────────── -->
<script>
window._VL = {}; // VariantLoaders namespace

const _esc = s => String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
function _errCard(msg) {
  return `<div class="task-card task17-card"><div class="task-content"><p style="color:#D69295;margin:0;">${_esc(msg)}</p></div></div>`;
}

/* ── Tasks 9/10/11/12 — shared task-play-card.js ─────────── */
['9','10','11','12'].forEach(n => {
  window._VL['task'+n] = async (slot, taskId) => {
    try {
      const res = await fetch(`/api/task${n}/tasks/${taskId}/play`);
      if (!res.ok) { slot.innerHTML = _errCard('Задание не найдено'); return; }
      const task = await res.json();
      slot.innerHTML = window[`renderTask${n}CardHTML`](taskId, task, { standalone: true });
      window[`initTask${n}Card`](slot, taskId, task, { standalone: true });
    } catch(e) { slot.innerHTML = _errCard(e.message); }
  };
});

/* ── Task 4 — Ударения ───────────────────────────────────── */
window._VL.task4 = async (slot, taskId) => {
  const uid = 't4-' + taskId;
  const esc = _esc;

  function stressIdx(word, wordStressed) {
    const p = wordStressed.indexOf('\u0301');
    return p >= 1 ? p - 1 : -1;
  }
  function renderWord(word, stressIndex, itemIndex) {
    return Array.from(word).map((ch, i) => {
      const display = i === stressIndex ? ch.toUpperCase() : ch;
      return `<span class="t4-ch" data-item="${itemIndex}" data-pos="${i}">${esc(display)}</span>`;
    }).join('');
  }
  function renderAnswerWord(word, correctIndex) {
    return Array.from(word).map((ch, i) => {
      if (i === correctIndex) return `<span class="t4-ch locked answer-ch">${ch.toUpperCase()}</span>`;
      return `<span class="t4-ch locked">${esc(ch)}</span>`;
    }).join('');
  }
  function renderCard(task) {
    const itemsHtml = task.items.map(it => `
      <div class="t4-item" id="t4-item-${taskId}-${it.item_index}">
        <button class="t4-num" data-index="${it.item_index}">${it.item_index}</button>
        <span class="t4-word" id="t4-word-${taskId}-${it.item_index}">
          ${renderWord(it.word, stressIdx(it.word, it.word_stressed), it.item_index)}
        </span>
      </div>`).join('');
    const bodyHtml = `<p class="task-prompt" style="margin:0;">Укажите варианты ответов, в которых <strong>верно</strong> выделено ударение.</p>
      <div class="t4-items" id="t4-items-${taskId}">${itemsHtml}</div>`;
    const controlsHtml = `<button type="button" class="task-send" id="t4-check-${taskId}">Проверить</button>`;
    return TaskCardShell.buildCardShell({ taskNum:4, taskId, bodyHtml, controlsHtml, uid });
  }
  function renderResult(data, task) {
    data.items.forEach(item => {
      const card   = document.getElementById(`t4-item-${taskId}-${item.item_index}`);
      const wordEl = document.getElementById(`t4-word-${taskId}-${item.item_index}`);
      card.classList.remove('selected');
      if      (item.is_correct && item.user_selected)  card.classList.add('result-correct');
      else if (item.is_correct && !item.user_selected) card.classList.add('result-missed');
      else if (!item.is_correct && item.user_selected) card.classList.add('result-wrong');
      else                                              card.classList.add('result-neutral');
      wordEl.innerHTML = renderAnswerWord(item.word, item.correct_stress_index);
    });
    const correctStr = data.correct_indices.join(', ');
    let itemsHtml = '';
    data.items.forEach(item => {
      const color = item.item_ok ? 'var(--brand)' : '#D69295';
      const icon  = item.item_ok ? '✓' : '✗';
      const ci = item.correct_stress_index;
      const correctDisplay = esc(item.word.slice(0,ci)) + `<strong>${item.word[ci].toUpperCase()}</strong>` + esc(item.word.slice(ci+1));
      let desc = item.is_correct ? `${correctDisplay} — ударение верное` : `${esc(item.word_stressed)} — неверное, правильно: ${correctDisplay}`;
      if (item.hint) desc += ` <span style="color:var(--text-secondary);font-size:13px;">— ${esc(item.hint)}</span>`;
      let ruleHtml = '';
      if (item.category_rule) ruleHtml = `<div class="t4-rule">${esc(item.category_name)}: ${esc(item.category_rule)}</div>`;
      itemsHtml += `<div class="t4-result-row"><span class="t4-result-icon" style="color:${color};">${icon}</span><div><span style="font-size:15px;">${item.item_index}. </span>${desc}${ruleHtml}</div></div>`;
    });
    const bodyHtml = `<p style="margin:0;font-size:15px;">Правильный ответ: <strong style="color:var(--brand);">${esc(correctStr)}</strong></p><div class="t4-result-block">${itemsHtml}</div>`;
    TaskCardShell.showResult(uid, data.all_correct, bodyHtml);
  }

  try {
    const res = await fetch(`/api/task4/tasks/${taskId}/play`);
    if (!res.ok) { slot.innerHTML = _errCard('Задание не найдено'); return; }
    const task = await res.json();
    slot.innerHTML = renderCard(task);

    const selected = new Set();
    const grid     = document.getElementById('t4-items-' + taskId);
    const checkBtn = document.getElementById('t4-check-' + taskId);

    grid.addEventListener('click', e => {
      const numBtn = e.target.closest('.t4-num');
      if (numBtn && !numBtn.disabled) {
        const idx  = +numBtn.dataset.index;
        const card = document.getElementById(`t4-item-${taskId}-${idx}`);
        if (selected.has(idx)) { selected.delete(idx); numBtn.classList.remove('selected'); card.classList.remove('selected'); }
        else                   { selected.add(idx);    numBtn.classList.add('selected');    card.classList.add('selected');    }
        return;
      }
      const ch = e.target.closest('.t4-ch');
      if (ch && !ch.classList.contains('locked')) {
        const itemIdx = ch.dataset.item;
        grid.querySelectorAll(`.t4-ch[data-item="${itemIdx}"]`).forEach(l => { if (l!==ch) l.classList.remove('marked'); });
        ch.classList.toggle('marked');
      }
    });
    checkBtn.addEventListener('click', async () => {
      checkBtn.disabled = true; checkBtn.textContent = '...';
      try {
        const data = await fetch(`/api/task4/tasks/${taskId}/check`, {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ selected: Array.from(selected) })
        }).then(r => r.json());
        if (data.error) { alert(data.error); return; }
        grid.querySelectorAll('.t4-ch').forEach(c => c.classList.add('locked'));
        TaskCardShell.lockCard(uid);
        renderResult(data, task);
      } finally { checkBtn.textContent = 'Проверить'; }
    });
  } catch(e) { slot.innerHTML = _errCard(e.message); }
};

/* ── Task 5 — Паронимы ───────────────────────────────────── */
window._VL.task5 = async (slot, taskId) => {
  const uid = 't5-' + taskId;
  const esc = _esc;
  let taskData = null;

  function escRx(s) { return String(s).replace(/[.*+?^${}()|[\]\\]/g,'\\$&'); }
  function renderSentences(items, resultItems) {
    return items.map(it => {
      const safe = esc(it.sentence);
      const rendered = safe.replace(new RegExp('\\{\\{' + escRx(it.highlighted_word) + '\\}\\}','i'), `<span class="t5-hl">${esc(it.highlighted_word)}</span>`);
      let stateClass='', extraHtml='';
      if (resultItems) {
        const ri = resultItems.find(r => r.item_index===it.item_index);
        if (ri && ri.is_error) { stateClass='state-error'; extraHtml=`<div style="margin-top:8px;font-size:13px;color:#D69295;">«${esc(ri.highlighted_word)}» → <strong style="color:var(--brand)">${esc(ri.correct_word)}</strong></div>`; }
        else stateClass='state-ok';
      }
      return `<div class="t5-sentence-item ${stateClass}"><div class="t5-sentence-num">${it.item_index}</div><div class="t5-sentence-text">${rendered}${extraHtml}</div></div>`;
    }).join('');
  }
  function renderCard() {
    const bodyHtml = `<p class="task-prompt" style="margin:0;">В одном из предложений <strong>НЕВЕРНО</strong> употреблено выделенное слово. Запишите пароним.</p>
      <div class="t5-sentences-wrap" id="t5-sentences-${taskId}">${renderSentences(taskData.items)}</div>`;
    const controlsHtml = `<input id="t5-input-${taskId}" class="task-input" type="text" placeholder="Введите правильное слово…" autocomplete="off" autocorrect="off" spellcheck="false">
      <button id="t5-check-${taskId}" class="task-send">Проверить</button>`;
    return TaskCardShell.buildCardShell({ taskNum:5, taskId, bodyHtml, controlsHtml, uid });
  }
  try {
    const res = await fetch(`/api/task5/tasks/${taskId}/play`);
    if (!res.ok) { slot.innerHTML = _errCard('Задание не найдено'); return; }
    taskData = await res.json();
    slot.innerHTML = renderCard();
    const input = document.getElementById('t5-input-'+taskId);
    const btn   = document.getElementById('t5-check-'+taskId);
    input.addEventListener('keydown', e => { if (e.key==='Enter') { e.preventDefault(); btn.click(); } });
    btn.addEventListener('click', async () => {
      const answer = input.value.trim();
      if (!answer) { input.focus(); return; }
      btn.disabled = true;
      try {
        const resp = await fetch(`/api/task5/tasks/${taskId}/check`, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({answer}) }).then(r=>r.json());
        const wrap = document.getElementById('t5-sentences-'+taskId);
        if (wrap) wrap.innerHTML = renderSentences(taskData.items, resp.items);
        TaskCardShell.lockCard(uid);
        TaskCardShell.showResult(uid, resp.is_correct, `<p style="margin:0;">Правильный ответ: <strong style="color:var(--brand);">${esc(resp.correct_answer)}</strong></p>`);
      } catch(e) { btn.disabled=false; alert('Ошибка при проверке.'); }
    });
  } catch(e) { slot.innerHTML = _errCard(e.message); }
};

/* ── Task 7 — Морфологические нормы ─────────────────────── */
window._VL.task7 = async (slot, taskId) => {
  const uid = 't7-' + taskId;
  const esc = _esc;
  let taskData = null;

  function renderPhrases(items, resultItems) {
    return items.map(it => {
      let stateClass='', extraHtml='';
      if (resultItems) {
        const ri = resultItems.find(r => r.item_index===it.item_index);
        if (ri && ri.is_error) { stateClass='state-error'; extraHtml=`<div style="margin-top:8px;font-size:13px;color:#D69295;">Ошибка → <strong style="color:var(--brand)">${esc(ri.correct_form)}</strong></div>`; }
        else stateClass='state-ok';
      }
      const hl = esc(it.display_phrase).replace(/\b([А-ЯЁA-Z]{2,})\b/g, '<span class="t7-hl">$1</span>');
      return `<div class="t7-phrase-item ${stateClass}"><div class="t7-phrase-num">${it.item_index}</div><div class="t7-phrase-text">${hl}${extraHtml}</div></div>`;
    }).join('');
  }
  function renderCard() {
    const bodyHtml = `<p class="task-prompt" style="margin:0;">В одном из выделенных слов допущена ошибка в образовании формы. Исправьте и запишите.</p>
      <div class="t7-phrases-wrap" id="t7-phrases-${taskId}">${renderPhrases(taskData.items)}</div>`;
    const controlsHtml = `<input id="t7-input-${taskId}" class="task-input" type="text" placeholder="Введите правильную форму…" autocomplete="off" autocorrect="off" spellcheck="false">
      <button id="t7-check-${taskId}" class="task-send">Проверить</button>`;
    return TaskCardShell.buildCardShell({ taskNum:7, taskId, bodyHtml, controlsHtml, uid });
  }
  try {
    const res = await fetch(`/api/task7/tasks/${taskId}/play`);
    if (!res.ok) { slot.innerHTML = _errCard('Задание не найдено'); return; }
    taskData = await res.json();
    slot.innerHTML = renderCard();
    const input = document.getElementById('t7-input-'+taskId);
    const btn   = document.getElementById('t7-check-'+taskId);
    input.addEventListener('keydown', e => { if (e.key==='Enter') { e.preventDefault(); btn.click(); } });
    btn.addEventListener('click', async () => {
      const answer = input.value.trim();
      if (!answer) { input.focus(); return; }
      btn.disabled = true;
      try {
        const resp = await fetch(`/api/task7/tasks/${taskId}/check`, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({answer}) }).then(r=>r.json());
        const wrap = document.getElementById('t7-phrases-'+taskId);
        if (wrap) wrap.innerHTML = renderPhrases(taskData.items, resp.items);
        TaskCardShell.lockCard(uid);
        TaskCardShell.showResult(uid, resp.is_correct, `<p style="margin:0;">Правильная форма: <strong style="color:var(--brand);">${esc(resp.correct_answer)}</strong></p>`);
      } catch(e) { btn.disabled=false; alert('Ошибка при проверке.'); }
    });
  } catch(e) { slot.innerHTML = _errCard(e.message); }
};

// Placeholders: React loaders set by Babel script below
window._VL.task17 = null;
window._VL.task18 = null;
window._VL.task19 = null;
</script>

<!-- ── React loaders (tasks 17, 18, 19) ─────────────────── -->
<script crossorigin src="https://unpkg.com/react@18/umd/react.development.js"></script>
<script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

<script type="text/babel">
(function() {
  const { useState, useEffect, useRef } = React;

  function parseDigits(text) {
    const parts = []; const re = /\((\d+)\)/g; let last=0, m;
    while ((m=re.exec(text))!==null) {
      if (m.index>last) parts.push({text:text.substring(last,m.index),digit:null});
      parts.push({text:m[0],digit:parseInt(m[1],10)});
      last=m.index+m[0].length;
    }
    if (last<text.length) parts.push({text:text.substring(last),digit:null});
    return parts;
  }

  /* ── Task 17 ──────────────────────────────────────────── */
  function Task17Item({ taskId }) {
    const [taskData,setTaskData]=useState(null);
