<div class="t9alt-page">

  <div class="t9alt-header">
    <div class="t9alt-header-top">
      <a href="/task9/theory" class="t9alt-back">← Теория задания №9</a>
      <h2 class="t9alt-title">Чередующиеся гласные в корне</h2>
    </div>
    <p class="t9alt-desc">
      Написание зависит от условия, а не от ударения — проверять однокоренными словами нельзя.
      Запомните правило для каждой группы корней.
    </p>
  </div>

  <!-- ──────────────── 1. По ударению ──────────────── -->
  <section class="t9alt-section">
    <div class="t9alt-section-header t9alt-stress">
      <span class="t9alt-section-badge">По ударению</span>
      <span class="t9alt-section-rule">Без ударения → одна буква, под ударением → другая</span>
    </div>

    <div class="t9alt-rules-grid">

      <div class="t9alt-rule-card">
        <div class="t9alt-rule-root">гар / гор</div>
        <div class="t9alt-rule-body">
          <div class="t9alt-rule-line"><span class="t9alt-badge-o">без ударения → О</span>
            <span class="t9alt-words">заг<em>о</em>рать, г<em>о</em>реть, уг<em>о</em>реть</span>
          </div>
          <div class="t9alt-rule-line"><span class="t9alt-badge-a">под ударением → А</span>
            <span class="t9alt-words">заг<em>а</em>р, уг<em>а</em>р, г<em>а</em>рь</span>
          </div>
        </div>
      </div>

      <div class="t9alt-rule-card">
        <div class="t9alt-rule-root">зар / зор</div>
        <div class="t9alt-rule-body">
          <div class="t9alt-rule-line"><span class="t9alt-badge-a">без ударения → А</span>
            <span class="t9alt-words">з<em>а</em>ря, з<em>а</em>рница, оз<em>а</em>рить</span>
          </div>
          <div class="t9alt-rule-line"><span class="t9alt-badge-o">под ударением → О или А</span>
            <span class="t9alt-words">з<em>о</em>рька, з<em>о</em>ри; з<em>а</em>рево</span>
          </div>
          <div class="t9alt-excl">Исключения: зоревать, зоревой</div>
        </div>
      </div>

      <div class="t9alt-rule-card">
        <div class="t9alt-rule-root">клан / клон</div>
        <div class="t9alt-rule-body">
          <div class="t9alt-rule-line"><span class="t9alt-badge-o">без ударения → О</span>
            <span class="t9alt-words">покл<em>о</em>ниться, накл<em>о</em>нить</span>
          </div>
          <div class="t9alt-rule-line"><span class="t9alt-badge-ao">под ударением → А или О</span>
            <span class="t9alt-words">кл<em>а</em>няться; накл<em>о</em>н</span>
          </div>
        </div>
      </div>

      <div class="t9alt-rule-card">
        <div class="t9alt-rule-root">твар / твор</div>
        <div class="t9alt-rule-body">
          <div class="t9alt-rule-line"><span class="t9alt-badge-o">без ударения → О</span>
            <span class="t9alt-words">тв<em>о</em>рить, тв<em>о</em>рение, тв<em>о</em>рец</span>
          </div>
          <div class="t9alt-rule-line"><span class="t9alt-badge-a">под ударением → А</span>
            <span class="t9alt-words">тв<em>а</em>рь</span>
          </div>
          <div class="t9alt-excl">Исключение: утварь</div>
        </div>
      </div>

    </div>
  </section>

  <!-- ──────────────── 2. По суффиксу -А- ──────────────── -->
  <section class="t9alt-section">
    <div class="t9alt-section-header t9alt-suffix">
      <span class="t9alt-section-badge">По суффиксу -А-</span>
      <span class="t9alt-section-rule">Если за корнем стоит суффикс <strong>-а-</strong> → И&thinsp;/&thinsp;им&thinsp;/&thinsp;ин;  без него → Е&thinsp;/&thinsp;ем&thinsp;/&thinsp;ен</span>
    </div>

    <div class="t9alt-suffix-table-wrap">
      <table class="t9alt-table">
        <thead>
          <tr>
            <th>Корень</th>
            <th>С суффиксом -А- → И</th>
            <th>Без суффикса -А- → Е</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>бир / бер</td><td>соб<em>и</em>рать</td><td>соб<em>е</em>рёт</td></tr>
          <tr><td>блист / блест</td><td>бл<em>и</em>стать</td><td>бл<em>е</em>стеть</td></tr>
          <tr><td>дир / дер</td><td>зад<em>и</em>рать</td><td>зад<em>е</em>рёт</td></tr>
          <tr><td>жиг / жег</td><td>сж<em>и</em>гать</td><td>сж<em>е</em>чь</td></tr>
          <tr><td>стил / стел</td><td>расст<em>и</em>лать</td><td>расст<em>е</em>лить</td></tr>
          <tr><td>тир / тер</td><td>ст<em>и</em>рать</td><td>ст<em>е</em>реть</td></tr>
          <tr><td>пир / пер</td><td>зап<em>и</em>рать</td><td>зап<em>е</em>реть</td></tr>
          <tr><td>мир / мер</td><td>ум<em>и</em>рать</td><td>ум<em>е</em>реть</td></tr>
          <tr><td>чит / чет</td><td>сч<em>и</em>тать</td><td>сч<em>е</em>т, почт<em>е</em>нный</td></tr>
          <tr><td>им / ин (ем / ен)</td><td>сн<em>им</em>ать, ж<em>ин</em>ать</td><td>сн<em>ем</em>у, ж<em>ен</em>ьшень</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ──────────────── 3. По следующей букве ──────────────── -->
  <section class="t9alt-section">
    <div class="t9alt-section-header t9alt-consonant">
      <span class="t9alt-section-badge">По следующей букве</span>
      <span class="t9alt-section-rule">Гласная зависит от согласной, которая идёт после корня</span>
    </div>

    <div class="t9alt-rules-grid">

      <div class="t9alt-rule-card">
        <div class="t9alt-rule-root">кас / кос</div>
        <div class="t9alt-rule-body">
          <div class="t9alt-rule-line"><span class="t9alt-badge-a">перед -А- → А</span>
            <span class="t9alt-words">к<em>а</em>саться, к<em>а</em>сание</span>
          </div>
          <div class="t9alt-rule-line"><span class="t9alt-badge-o">иначе → О</span>
            <span class="t9alt-words">к<em>о</em>снуться, прик<em>о</em>снуться</span>
          </div>
        </div>
      </div>

      <div class="t9alt-rule-card">
        <div class="t9alt-rule-root">лаг / лож</div>
        <div class="t9alt-rule-body">
          <div class="t9alt-rule-line"><span class="t9alt-badge-a">перед Г → А</span>
            <span class="t9alt-words">пол<em>а</em>гать, изл<em>а</em>гать, прил<em>а</em>гать</span>
          </div>
          <div class="t9alt-rule-line"><span class="t9alt-badge-o">перед Ж → О</span>
            <span class="t9alt-words">пол<em>о</em>жить, изл<em>о</em>жение, прил<em>о</em>жить</span>
          </div>
          <div class="t9alt-excl">Исключение: полог</div>
        </div>
      </div>

      <div class="t9alt-rule-card">
        <div class="t9alt-rule-root">раст / рос</div>
        <div class="t9alt-rule-body">
          <div class="t9alt-rule-line"><span class="t9alt-badge-a">перед СТ и Щ → А</span>
            <span class="t9alt-words">р<em>а</em>стение, р<em>а</em>сти, р<em>а</em>щу</span>
          </div>
          <div class="t9alt-rule-line"><span class="t9alt-badge-o">иначе → О</span>
            <span class="t9alt-words">р<em>о</em>сли, р<em>о</em>сток, выр<em>о</em>сший</span>
          </div>
          <div class="t9alt-excl">Исключения: росток, Ростов, Ростислав, отрасль</div>
        </div>
      </div>

      <div class="t9alt-rule-card">
        <div class="t9alt-rule-root">скак / скоч</div>
        <div class="t9alt-rule-body">
          <div class="t9alt-rule-line"><span class="t9alt-badge-a">перед К → А</span>
            <span class="t9alt-words">ск<em>а</em>кать, поск<em>а</em>кать</span>
          </div>
          <div class="t9alt-rule-line"><span class="t9alt-badge-o">перед Ч → О</span>
            <span class="t9alt-words">ск<em>о</em>чить, выск<em>о</em>чить</span>
          </div>
          <div class="t9alt-excl">Исключения: скачок, скачу</div>
        </div>
      </div>

    </div>
  </section>

  <!-- ──────────────── 4. По значению ──────────────── -->
  <section class="t9alt-section">
    <div class="t9alt-section-header t9alt-meaning">
      <span class="t9alt-section-badge">По значению</span>
      <span class="t9alt-section-rule">Гласная зависит от смысла слова</span>
    </div>

    <div class="t9alt-rules-grid">

      <div class="t9alt-rule-card">
        <div class="t9alt-rule-root">мак / мок</div>
        <div class="t9alt-rule-body">
          <div class="t9alt-rule-line"><span class="t9alt-badge-a">«окунать, погружать» → А</span>
            <span class="t9alt-words">м<em>а</em>кать хлеб в молоко</span>
          </div>
          <div class="t9alt-rule-line"><span class="t9alt-badge-o">«намокнуть, впитывать» → О</span>
            <span class="t9alt-words">м<em>о</em>крый, пром<em>о</em>кнуть, м<em>о</em>кнуть под дождём</span>
          </div>
        </div>
      </div>

      <div class="t9alt-rule-card">
        <div class="t9alt-rule-root">равн / ровн</div>
        <div class="t9alt-rule-body">
          <div class="t9alt-rule-line"><span class="t9alt-badge-a">«одинаковый, сравнивать» → А</span>
            <span class="t9alt-words">р<em>а</em>вный, ур<em>а</em>внение, ср<em>а</em>внить</span>
          </div>
          <div class="t9alt-rule-line"><span class="t9alt-badge-o">«прямой, гладкий, ровный» → О</span>
            <span class="t9alt-words">р<em>о</em>вный, пор<em>о</em>внять дорогу</span>
          </div>
          <div class="t9alt-excl">Исключения: равнина, поровну, ровесник</div>
        </div>
      </div>

      <div class="t9alt-rule-card">
        <div class="t9alt-rule-root">плав / плов / плыв</div>
        <div class="t9alt-rule-body">
          <div class="t9alt-rule-line"><span class="t9alt-badge-a">почти всегда → А</span>
            <span class="t9alt-words">пл<em>а</em>вать, пл<em>а</em>вник, пл<em>а</em>вучий</span>
          </div>
          <div class="t9alt-rule-line"><span class="t9alt-badge-o">исключения с О и Ы</span>
            <span class="t9alt-words">пл<em>о</em>вец, пл<em>о</em>вчиха; пл<em>ы</em>вун</span>
          </div>
        </div>
      </div>

    </div>
  </section>

</div>

