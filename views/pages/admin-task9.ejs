<div class="admin-page">
  <h2 class="admin-page__title">Задание №9 — Управление</h2>

  <!-- Вкладки -->
  <div class="admin-task-tabs-bar">
    <button class="tab-btn active" onclick="switchTab('words',this)">Словарь слов</button>
    <button class="tab-btn" onclick="switchTab('tasks',this)">Готовые задания</button>
    <button class="tab-btn" onclick="switchTab('generate',this)">Генерация</button>
    <button class="tab-btn" onclick="switchTab('groups',this)">Группы вариантов</button>
  </div>

  <!-- ══ ВКЛАДКА: СЛОВАРЬ ══════════════════════════════════ -->
  <div id="tab-words">

    <div class="admin-section">
      <h3>Добавить слово</h3>
      <form id="word-form" class="admin-form">
        <input type="hidden" id="word-id">
        <div class="word-form-grid">
          <div class="form-group">
            <label>Слово с пропуском</label>
            <input type="text" id="word-display" placeholder="г_реть" required>
          </div>
          <div class="form-group">
            <label>Правильная буква</label>
            <input type="text" id="word-vowel" maxlength="1" placeholder="о" required oninput="autoSelectPair(this.value)">
          </div>
          <div class="form-group">
            <label>Пара букв</label>
            <select id="word-pair" required>
              <option value="">—</option>
              <option value="о/а">о / а</option>
              <option value="е/и">е / и</option>
              <option value="у/ю">у / ю</option>
              <option value="о/ё">о / ё</option>
              <option value="е/я">е / я</option>
            </select>
          </div>
          <div class="form-group">
            <label>Категория</label>
            <select id="word-category" required onchange="onCategoryChange(this.value)">
              <option value="">—</option>
              <option value="alternating">Чередующиеся</option>
              <option value="verifiable">Безударные проверяемые</option>
              <option value="unverifiable">Безударные непроверяемые</option>
            </select>
          </div>
        </div>

        <!-- Дополнительные поля в зависимости от категории -->
        <div id="extra-verifiable" style="display:none;margin-top:12px;">
          <div class="form-group">
            <label>Проверочное слово</label>
            <input type="text" id="word-verification" placeholder="гор — горе, гора">
          </div>
        </div>
        <div id="extra-alternating" style="display:none;margin-top:12px;">
          <div class="form-group">
            <label>Правило чередования</label>
            <select id="word-alternation-rule">
              <option value="">— выберите правило —</option>
              <optgroup label="о / а">
                <option value="гор/гар">гор / гар (без ударения — о)</option>
                <option value="зор/зар">зор / зар (без ударения — за-)</option>
                <option value="твор/твар">твор / твар (без ударения — о)</option>
                <option value="клон/клан">клон / клан (без ударения — о)</option>
                <option value="кос/кас">кос / кас (перед -а- → кас)</option>
                <option value="лог/лаг">лог / лаг (перед -а- → лаг)</option>
                <option value="мок/мак">мок / мак (мок — пропускать, мак — погружать)</option>
                <option value="ровн/равн">ровн / равн</option>
                <option value="скак/скоч">скак / скоч</option>
                <option value="плов/плав">плов / плав / плыв</option>
              </optgroup>
              <optgroup label="е / и">
                <option value="бер/бир">бер / бир (беру — забирать)</option>
                <option value="дер/дир">дер / дир (деру — задирать)</option>
                <option value="мер/мир">мер / мир (умереть — умирать)</option>
                <option value="пер/пир">пер / пир (запереть — запирать)</option>
                <option value="тер/тир">тер / тир (стереть — стирать)</option>
                <option value="стел/стил">стел / стил (стелить — застилать)</option>
                <option value="жег/жиг">жег / жиг (выжечь — выжигать)</option>
                <option value="блест/блист">блист / блест (блистать — блестеть)</option>
                <option value="чет/чит">чет / чит (вычет — вычитать)</option>
              </optgroup>
              <optgroup label="а(я) / им, а(я) / ин">
                <option value="ним/на">ним / -н(а)-</option>
                <option value="жим/жа">жим / -ж(а)-</option>
                <option value="чин/ча">чин / -ч(а)-</option>
                <option value="мин/мя">мин / -м(я)-</option>
              </optgroup>
            </select>
          </div>
        </div>

        <div id="extra-group" style="margin-top:12px;">
          <div class="form-group" style="max-width:320px;">
            <label>Группа вариантов <span style="color:var(--text-secondary);font-weight:400;">(ID или пусто)</span></label>
            <div style="display:flex;gap:8px;align-items:center;">
              <input type="number" id="word-group-id" placeholder="—" min="1" style="width:80px;">
              <button type="button" class="btn btn-secondary btn-sm" id="btn-new-group" style="display:none;" onclick="createNewGroup()">Новая группа</button>
              <span id="group-hint" style="font-size:13px;color:var(--text-secondary);"></span>
            </div>
          </div>
        </div>

        <div style="display:flex;gap:8px;margin-top:12px;">
          <button type="submit" class="btn" id="word-submit-btn">Добавить</button>
          <button type="button" class="btn btn-secondary" id="word-cancel-btn" style="display:none;" onclick="cancelWordEdit()">Отмена</button>
        </div>
      </form>
    </div>

    <!-- Фильтр -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;max-width:480px;margin-bottom:16px;">
      <div class="form-group">
        <label>Фильтр: категория</label>
        <select id="filter-category" onchange="loadWords()">
          <option value="">Все</option>
          <option value="alternating">Чередующиеся</option>
          <option value="verifiable">Проверяемые</option>
          <option value="unverifiable">Непроверяемые</option>
        </select>
      </div>
      <div class="form-group">
        <label>Фильтр: пара</label>
        <select id="filter-pair" onchange="loadWords()">
          <option value="">Все</option>
          <option value="о/а">о / а</option>
          <option value="е/и">е / и</option>
          <option value="у/ю">у / ю</option>
          <option value="о/ё">о / ё</option>
          <option value="е/я">е / я</option>
        </select>
      </div>
    </div>

    <div class="admin-section">
      <table class="admin-table" id="words-table">
        <thead>
          <tr><th>Слово</th><th>Буква</th><th>Пара</th><th>Категория</th><th>Доп. инфо</th><th>Группа</th><th>Действия</th></tr>
        </thead>
        <tbody id="words-tbody">
          <tr><td colspan="5" style="color:var(--text-secondary);">Загрузка...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ══ ВКЛАДКА: ГРУППЫ ВАРИАНТОВ ════════════════════════ -->
  <div id="tab-groups" style="display:none;">
    <div class="admin-section">
      <h3>Группы вариантов одного слова</h3>
      <p style="color:var(--text-secondary);font-size:14px;margin-bottom:16px;">
        Варианты одного слова с пропуском в разных позициях (например, <strong>д..зертир</strong> и <strong>дез..ртир</strong>).
        В одном задании из группы используется только одно слово.
      </p>
      <div id="groups-list" style="display:flex;flex-direction:column;gap:12px;">
        <p style="color:var(--text-secondary);">Загрузка...</p>
      </div>
    </div>
  </div>

  <!-- ══ ВКЛАДКА: ГЕНЕРАЦИЯ ════════════════════════════════ -->
  <div id="tab-generate" style="display:none;">
    <div class="admin-section">
      <h3>Сгенерировать задание</h3>
      <p style="color:var(--text-secondary);font-size:14px;margin-bottom:16px;">
        Задание создаётся автоматически из словаря. Готовое задание сохраняется и доступно ученикам.
      </p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;max-width:700px;margin-bottom:16px;">
        <div class="form-group">
          <label>Категория</label>
          <select id="gen-category">
            <option value="">Все</option>
            <option value="alternating">Чередующиеся</option>
            <option value="verifiable">Проверяемые</option>
            <option value="unverifiable">Непроверяемые</option>
          </select>
        </div>
        <div class="form-group">
          <label>Пара букв</label>
          <select id="gen-pair">
            <option value="">Все</option>
            <option value="о/а">о / а</option>
            <option value="е/и">е / и</option>
            <option value="у/ю">у / ю</option>
            <option value="о/ё">о / ё</option>
            <option value="е/я">е / я</option>
          </select>
        </div>
        <div class="form-group">
          <label>Правильных строк</label>
          <select id="gen-correct-count">
            <option value="random" selected>случайно (2–4)</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="4">4</option>
          </select>
        </div>
      </div>
      <!-- Дополнительные фильтры для чередующихся -->
      <div id="adm-alt-filters" class="alternation-filters" style="display:none;max-width:700px;">
        <div class="alt-filter-section">
          <div class="alt-filter-label">Тип чередования <span class="alt-filter-hint">пусто = все</span></div>
          <div class="toggle-chips" id="adm-type-chips">
            <button class="toggle-chip" data-type="stress">По ударению</button>
            <button class="toggle-chip" data-type="suffix">По суффиксу -А</button>
            <button class="toggle-chip" data-type="consonant">По следующей букве</button>
            <button class="toggle-chip" data-type="meaning">По значению</button>
          </div>
        </div>
        <div class="alt-filter-section">
          <div class="alt-filter-label">Конкретные корни <span class="alt-filter-hint">пусто = все выбранных типов</span></div>
          <div class="toggle-chips" id="adm-root-chips"></div>
        </div>
      </div>
      <button class="btn" id="btn-generate-task" style="margin-top:16px;">Сгенерировать и сохранить</button>
      <div id="gen-result" style="margin-top:16px;"></div>
    </div>

    <div class="admin-section" style="margin-top:32px;">
      <h3>Сгенерированные задания</h3>
      <div id="gen-tasks-list" style="display:flex;flex-direction:column;gap:8px;">
        <p style="color:var(--text-secondary);">Загрузка...</p>
      </div>
    </div>
  </div>

  <!-- ══ ВКЛАДКА: ЗАДАНИЯ ══════════════════════════════════ -->
  <div id="tab-tasks" style="display:none;">

    <div class="admin-section">
      <h3>Создать задание вручную</h3>
      <p style="color:var(--text-secondary);font-size:14px;margin-bottom:16px;">
        Выберите 3 слова для каждой из 5 строк и отметьте правильные строки (2–5).
      </p>
      <div id="task-builder">
        <!-- Строки задания -->
        <div id="task-rows" style="display:flex;flex-direction:column;gap:12px;"></div>
        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:16px;align-items:center;">
          <button type="button" class="btn" id="btn-save-task">Сохранить задание</button>
          <button type="button" class="btn btn-secondary" id="task-edit-cancel" style="display:none;">Отменить редактирование</button>
        </div>
      </div>
    </div>

    <div class="admin-section" style="margin-top:32px;">
      <h3>Список заданий</h3>
      <div id="tasks-list" style="display:flex;flex-direction:column;gap:8px;">
        <p style="color:var(--text-secondary);">Загрузка...</p>
      </div>
    </div>
  </div>
</div>

<style>
.word-form-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 2fr;
  gap: 12px;
  align-items: start;
}
@media (max-width: 700px) {
  .word-form-grid { grid-template-columns: 1fr 1fr; }
}
.admin-table { width: 100%; border-collapse: collapse; font-size: 14px; }
.admin-table th, .admin-table td {
  padding: 10px 12px; text-align: left;
  border-bottom: 1px solid var(--glass-border);
}
.admin-table th { color: var(--text-secondary); font-weight: 600; }
.task-row-builder {
  display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
  padding: 12px 16px;
  background: var(--bg-secondary);
  border: 1px solid var(--glass-border);
  border-radius: 8px;
}
.task-row-builder.correct-row { border-color: var(--brand); }
</style>

<script src="/js/admin-task-shared.js"></script>
<script>
const escHtml = (s) => AdminTasks.escHtml(s);
const esc = (s) => AdminTasks.escAttr(s);

const CATEGORY_LABELS = { alternating: 'Чередующиеся', verifiable: 'Проверяемые', unverifiable: 'Непроверяемые' };

// Показ/скрытие дополнительных полей по категории
function onCategoryChange(value) {
  document.getElementById('extra-verifiable').style.display  = value === 'verifiable'  ? '' : 'none';
  document.getElementById('extra-alternating').style.display = value === 'alternating' ? '' : 'none';
}

// Автоподбор пары по введённой букве
const VOWEL_TO_PAIR = { 'а':'о/а', 'о':'о/а', 'и':'е/и', 'е':'е/и', 'ю':'у/ю', 'у':'у/ю', 'ё':'о/ё', 'я':'е/я' };
function autoSelectPair(letter) {
  const pair = VOWEL_TO_PAIR[letter.toLowerCase()];
  const select = document.getElementById('word-pair');
  // Подставляем только если пара не выбрана вручную или если поле пустое
  if (pair && !select.dataset.manuallyChanged) {
    select.value = pair;
  }
}
// Фиксируем ручное изменение пары
document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('word-pair').addEventListener('change', function() {
    this.dataset.manuallyChanged = '1';
  });
});

let allWords = [];

const switchTab = AdminTasks.createSwitchTab({
  tabIds: ['words', 'tasks', 'generate', 'groups'],
  onShow: {
    tasks() { loadAllWords(); loadTasks(); },
    generate() { loadGenTasks(); },
    groups() { loadGroups(); },
  },
});

/* ─── СЛОВАРЬ ────────────────────────────────── */

async function loadWords() {
  const cat  = document.getElementById('filter-category').value;
  const pair = document.getElementById('filter-pair').value;
  const params = new URLSearchParams();
  if (cat)  params.set('category',   cat);
  if (pair) params.set('vowel_pair', pair);
  const res = await fetch('/api/task9/words?' + params);
  const words = await res.json();
  const tbody = document.getElementById('words-tbody');
  if (!words.length) {
    tbody.innerHTML = '<tr><td colspan="5" style="color:var(--text-secondary);">Слов нет</td></tr>';
    return;
  }
  tbody.innerHTML = words.map(w => `
    <tr>
      <td style="font-family:monospace;font-size:16px;">${w.word_display}</td>
      <td>${w.correct_vowel}</td>
      <td>${w.vowel_pair}</td>
      <td>${CATEGORY_LABELS[w.category] || w.category}</td>
      <td style="color:var(--text-secondary);font-size:13px;">
        ${w.verification_word ? '🔍 ' + w.verification_word : ''}
        ${w.alternation_rule  ? '⇄ ' + w.alternation_rule   : ''}
      </td>
      <td style="font-size:13px;">
        ${w.word_group_id
          ? `<span style="background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:4px;padding:2px 6px;color:var(--brand);">G${w.word_group_id}</span>`
          : '<span style="color:var(--text-secondary);">—</span>'}
      </td>
      <td>
        <button class="btn-icon" onclick="editWord(${w.id},'${esc(w.word_display)}','${w.correct_vowel}','${w.vowel_pair}','${w.category}','${esc(w.verification_word||'')}','${esc(w.alternation_rule||'')}',${w.word_group_id||''})" title="Редактировать"><img src="/images/type=edit, size=16.svg" width="16" height="16"></button>
        <button class="btn-icon btn-icon--delete" onclick="deleteWord(${w.id})" title="Удалить"><img src="/images/type=delete, size=16.svg" width="16" height="16"></button>
      </td>
    </tr>
  `).join('');
}

document.getElementById('word-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const id       = document.getElementById('word-id').value;
  const category = document.getElementById('word-category').value;
  const groupVal = document.getElementById('word-group-id').value;
  const body = {
    word_display:      document.getElementById('word-display').value.trim(),
    correct_vowel:     document.getElementById('word-vowel').value.trim(),
    vowel_pair:        document.getElementById('word-pair').value,
    category,
    verification_word: category === 'verifiable'  ? (document.getElementById('word-verification').value.trim() || null)      : null,
    alternation_rule:  category === 'alternating' ? (document.getElementById('word-alternation-rule').value   || null) : null,
    word_group_id:     groupVal ? Number(groupVal) : null
  };
  const url    = id ? `/api/task9/words/${id}` : '/api/task9/words';
  const method = id ? 'PUT' : 'POST';
  console.log('Отправляем:', method, url, body);
  try {
    const res  = await fetch(url, { method, headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
    const data = await res.json();
    console.log('Ответ сервера:', data);
    if (data.error) { alert('Ошибка: ' + data.error); return; }
    cancelWordEdit();
    loadWords();
  } catch (err) {
    alert('Ошибка сети: ' + err.message);
    console.error(err);
  }
});

function editWord(id, display, vowel, pair, category, verificationWord, alternationRule, groupId) {
  document.getElementById('word-id').value      = id;
  document.getElementById('word-display').value = display;
  document.getElementById('word-vowel').value   = vowel;
  const pairSelect = document.getElementById('word-pair');
  pairSelect.value = pair;
  delete pairSelect.dataset.manuallyChanged;
  document.getElementById('word-category').value = category;
  document.getElementById('word-group-id').value = groupId || '';
  document.getElementById('btn-new-group').style.display = groupId ? 'none' : '';
  updateGroupHint(groupId);
  // Сначала показываем нужный блок, потом ставим значение
  onCategoryChange(category);
  document.getElementById('word-verification').value     = verificationWord || '';
  document.getElementById('word-alternation-rule').value = alternationRule  || '';
  console.log('editWord: category=', category, 'alternationRule=', alternationRule, '→ select value after set:', document.getElementById('word-alternation-rule').value);
  document.getElementById('word-submit-btn').textContent = 'Сохранить';
  document.getElementById('word-cancel-btn').style.display = '';
  document.getElementById('word-form').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function cancelWordEdit() {
  document.getElementById('word-id').value            = '';
  document.getElementById('word-display').value       = '';
  document.getElementById('word-vowel').value         = '';
  document.getElementById('word-verification').value  = '';
  document.getElementById('word-alternation-rule').value = '';
  document.getElementById('word-group-id').value      = '';
  document.getElementById('btn-new-group').style.display = '';
  document.getElementById('group-hint').textContent   = '';
  const pairSelect = document.getElementById('word-pair');
  pairSelect.value = '';
  delete pairSelect.dataset.manuallyChanged;
  document.getElementById('word-category').value = '';
  onCategoryChange('');
  document.getElementById('word-submit-btn').textContent = 'Добавить';
  document.getElementById('word-cancel-btn').style.display = 'none';
}

async function deleteWord(id) {
  if (!confirm('Удалить слово?')) return;
  await fetch(`/api/task9/words/${id}`, { method: 'DELETE' });
  loadWords();
}

/* ─── ЗАДАНИЯ ────────────────────────────────── */

let editingTaskId = null;

/* ─── ПОИСК В SELECT ─────────────────────────── */

function initSelectSearch(sel) {
  let query = '';
  let timer = null;
  sel.addEventListener('keydown', (e) => {
    if (e.key === 'Backspace') {
      e.preventDefault();
      query = query.slice(0, -1);
    } else if (e.key.length === 1 && !e.ctrlKey && !e.altKey && !e.metaKey) {
      e.preventDefault();
      query += e.key.toLowerCase();
    } else {
      return;
    }
    clearTimeout(timer);
    timer = setTimeout(() => { query = ''; }, 1400);
    if (!query) return;
    const match = [...sel.options].find(o => o.value && o.text.toLowerCase().includes(query));
    if (match) sel.value = match.value;
  });
}

async function loadAllWords() {
  const res = await fetch('/api/task9/words');
  allWords = await res.json();
  renderTaskBuilder();
}

function renderTaskBuilder() {
  const container = document.getElementById('task-rows');
  container.innerHTML = '';
  for (let i = 1; i <= 5; i++) {
    const div = document.createElement('div');
    div.className = 'task-row-builder';
    div.dataset.rowIndex = i;
    div.innerHTML = `
      <label style="display:flex;align-items:center;gap:6px;cursor:pointer;white-space:nowrap;">
        <input type="checkbox" data-correct class="row-correct-cb" onchange="this.closest('.task-row-builder').classList.toggle('correct-row',this.checked)">
        Строка ${i} ✓
      </label>
      ${[1,2,3].map(j => `
        <select class="word-select" data-cell="${j}">
          <option value="">— слово ${j} —</option>
          ${allWords.map(w => `<option value="${w.id}">${escHtml(w.word_display)} (${escHtml(w.correct_vowel)})</option>`).join('')}
        </select>`).join('')}
    `;
    container.appendChild(div);
    div.querySelectorAll('select[data-cell]').forEach(initSelectSearch);
  }
}

function cancelTaskEdit(clearBuilder) {
  editingTaskId = null;
  document.getElementById('btn-save-task').textContent = 'Сохранить задание';
  document.getElementById('task-edit-cancel').style.display = 'none';
  if (clearBuilder !== false) renderTaskBuilder();
}

async function editTask(id) {
  await loadAllWords();
  const res = await fetch('/api/task9/tasks/' + id);
  if (!res.ok) {
    alert('Не удалось загрузить задание');
    return;
  }
  const task = await res.json();
  editingTaskId = id;
  const rowsByIndex = {};
  for (const r of task.rows) {
    rowsByIndex[r.row_index] = r;
  }
  document.querySelectorAll('.task-row-builder').forEach((rowEl) => {
    const idx = +rowEl.dataset.rowIndex;
    const row = rowsByIndex[idx];
    if (!row) return;
    const cb = rowEl.querySelector('[data-correct]');
    const ok = !!row.is_correct;
    cb.checked = ok;
    rowEl.classList.toggle('correct-row', ok);
    const words = [...row.words].sort((a, b) => a.cell_index - b.cell_index);
    words.forEach((w, i) => {
      const sel = rowEl.querySelector('select[data-cell="' + (i + 1) + '"]');
      if (sel) sel.value = String(w.word_id);
    });
  });
  document.getElementById('btn-save-task').textContent = 'Сохранить изменения';
  document.getElementById('task-edit-cancel').style.display = '';
  document.getElementById('task-builder').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

document.getElementById('task-edit-cancel').addEventListener('click', () => cancelTaskEdit(true));

document.getElementById('btn-save-task').addEventListener('click', async () => {
  const rowEls = document.querySelectorAll('.task-row-builder');
  const rows = [];
  for (const rowEl of rowEls) {
    const word_ids = Array.from(rowEl.querySelectorAll('select[data-cell]')).map(s => +s.value);
    if (word_ids.some(id => !id)) { alert('Выберите все слова во всех строках'); return; }
    rows.push({
      row_index: +rowEl.dataset.rowIndex,
      is_correct: rowEl.querySelector('[data-correct]').checked,
      word_ids
    });
  }
  const correct = rows.filter(r => r.is_correct).length;
  if (correct < 2 || correct > 5) { alert('Отметьте от 2 до 5 правильных строк'); return; }

  if (editingTaskId) {
    const res = await fetch('/api/task9/tasks/' + editingTaskId, {
      method: 'PUT', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ rows })
    });
    const data = await res.json();
    if (data.error) { alert(data.error); return; }
    alert('Задание #' + editingTaskId + ' обновлено');
    cancelTaskEdit(true);
    loadTasks();
    return;
  }

  const res = await fetch('/api/task9/tasks', {
    method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ rows })
  });
  const data = await res.json();
  if (data.error) { alert(data.error); return; }
  alert(`Задание #${data.id} создано`);
  cancelTaskEdit(true);
  loadTasks();
});

async function loadTasks() {
  const res = await fetch('/api/task9/tasks');
  const tasks = await res.json();
  const list = document.getElementById('tasks-list');
  if (!tasks.length) {
    list.innerHTML = '<p style="color:var(--text-secondary);">Заданий пока нет</p>';
    return;
  }
  list.innerHTML = tasks.map(t => `
    <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:var(--bg-secondary);border:1px solid var(--glass-border);border-radius:var(--radius-lg);">
      <span>
        Задание #${t.id}
        ${t.is_generated ? '<span style="font-size:11px;color:var(--text-secondary);margin-left:8px;">(сгенерировано)</span>' : ''}
        <span style="font-size:12px;color:var(--text-secondary);margin-left:8px;">${new Date(t.created_at).toLocaleDateString('ru')}</span>
      </span>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <a href="/task9/${t.id}" target="_blank" class="btn btn-sm btn-secondary">Открыть</a>
        <button type="button" class="btn btn-sm" onclick="editTask(${t.id})">Редактировать</button>
        <button type="button" class="btn btn-sm btn-secondary" onclick="deleteTask(${t.id})">Удалить</button>
      </div>
    </div>
  `).join('');
}

async function deleteTask(id) {
  if (!confirm(`Удалить задание #${id}?`)) return;
  await fetch(`/api/task9/tasks/${id}`, { method: 'DELETE' });
  loadTasks();
}

/* ─── ГРУППЫ ВАРИАНТОВ ───────────────────────── */

async function createNewGroup() {
  const wordId = document.getElementById('word-id').value;
  if (!wordId) { alert('Сначала откройте слово для редактирования'); return; }
  const res  = await fetch('/api/task9/words/new-group', {
    method: 'POST', headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ word_id: Number(wordId) })
  });
  const data = await res.json();
  if (data.error) { alert(data.error); return; }
  document.getElementById('word-group-id').value = data.word_group_id;
  document.getElementById('btn-new-group').style.display = 'none';
  updateGroupHint(data.word_group_id);
  loadWords();
}

function updateGroupHint(groupId) {
  const hint = document.getElementById('group-hint');
  hint.textContent = groupId ? `Группа G${groupId} — слова с этим ID не попадут вместе в одно задание` : '';
}

document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('word-group-id').addEventListener('input', function() {
    updateGroupHint(this.value ? Number(this.value) : null);
    document.getElementById('btn-new-group').style.display = this.value ? 'none' : '';
  });
});

async function loadGroups() {
  const res = await fetch('/api/task9/words/groups');
  const groups = await res.json();
  const list = document.getElementById('groups-list');
  if (!groups.length) {
    list.innerHTML = '<p style="color:var(--text-secondary);">Групп пока нет. Откройте слово на вкладке «Словарь» и нажмите «Новая группа».</p>';
    return;
  }
  list.innerHTML = groups.map(g => `
    <div style="padding:14px 16px;background:var(--bg-secondary);border:1px solid var(--glass-border);border-radius:var(--radius-lg);">
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px;">
        <span style="background:var(--glass-bg);border:1px solid var(--brand);border-radius:4px;padding:2px 8px;color:var(--brand);font-size:13px;font-weight:600;">G${g.id}</span>
        <span style="color:var(--text-secondary);font-size:13px;">${g.words.length} вариант(а)</span>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        ${g.words.map(w => `
          <div style="display:flex;align-items:center;gap:6px;padding:6px 10px;background:var(--bg-tertiary);border:1px solid var(--glass-border);border-radius:var(--radius-lg);font-family:monospace;">
            <span>${w.word_display}</span>
            <span style="color:var(--text-secondary);font-size:12px;">(${w.correct_vowel})</span>
            <button onclick="removeFromGroup(${w.id})" style="background:none;border:none;color:var(--text-secondary);cursor:pointer;padding:0 2px;font-size:14px;" title="Убрать из группы">✕</button>
          </div>
        `).join('')}
      </div>
    </div>
  `).join('');
}

async function removeFromGroup(wordId) {
  await fetch(`/api/task9/words/${wordId}/group`, {
    method: 'PUT', headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ word_group_id: null })
  });
  loadGroups();
  loadWords();
}

/* ─── ГЕНЕРАЦИЯ ──────────────────────────────── */

/* Каскадный фильтр чередования */
let admAltTypeRules = {};
let admSelectedTypes = new Set();
let admSelectedRoots = new Set();

(async function loadAdmAltTypes() {
  try {
    admAltTypeRules = await fetch('/api/task9/alternation-types').then(r => r.json());
    renderAdmRootChips();
  } catch (_) {}
})();

document.getElementById('gen-category').addEventListener('change', function () {
  const show = this.value === 'alternating';
  document.getElementById('adm-alt-filters').style.display = show ? '' : 'none';
  if (!show) {
    admSelectedTypes.clear(); admSelectedRoots.clear();
    document.querySelectorAll('#adm-type-chips .toggle-chip').forEach(c => c.classList.remove('active'));
  }
});

document.getElementById('adm-type-chips').addEventListener('click', e => {
  const chip = e.target.closest('.toggle-chip[data-type]');
  if (!chip) return;
  const t = chip.dataset.type;
  if (admSelectedTypes.has(t)) { admSelectedTypes.delete(t); chip.classList.remove('active'); }
  else { admSelectedTypes.add(t); chip.classList.add('active'); }
  pruneAdmRoots(); renderAdmRootChips();
});

function admVisibleRoots() {
  if (!admSelectedTypes.size) return Object.values(admAltTypeRules).flat();
  return [...admSelectedTypes].flatMap(t => admAltTypeRules[t] || []);
}

function pruneAdmRoots() {
  const visible = new Set(admVisibleRoots());
  for (const r of [...admSelectedRoots]) { if (!visible.has(r)) admSelectedRoots.delete(r); }
}

function renderAdmRootChips() {
  const container = document.getElementById('adm-root-chips');
  container.innerHTML = admVisibleRoots().map(r => {
    const active = admSelectedRoots.has(r) ? ' active' : '';
    return `<button class="toggle-chip toggle-chip-root${active}" data-root="${r}">${r}</button>`;
  }).join('');
}

document.getElementById('adm-root-chips').addEventListener('click', e => {
  const chip = e.target.closest('.toggle-chip[data-root]');
  if (!chip) return;
  const r = chip.dataset.root;
  if (admSelectedRoots.has(r)) { admSelectedRoots.delete(r); chip.classList.remove('active'); }
  else { admSelectedRoots.add(r); chip.classList.add('active'); }
});

AdminTasks.bindGenerateButton({
  generateUrl: '/api/task9/generate',
  buildBody() {
    const v = document.getElementById('gen-correct-count').value;
    const body = { correct_count: v === 'random' ? (2 + Math.floor(Math.random() * 3)) : +v };
    const cat = document.getElementById('gen-category').value;
    const pair = document.getElementById('gen-pair').value;
    if (cat) body.category = cat;
    if (pair) body.vowel_pair = pair;
    if (cat === 'alternating') {
      if (admSelectedRoots.size) body.alternation_rules = [...admSelectedRoots];
      else if (admSelectedTypes.size) body.alternation_types = [...admSelectedTypes];
    }
    return body;
  },
  formatSuccess(data) {
    return (
      '<span style="color:#A4E2D0;">✓ Задание #' +
      data.id +
      ' создано.</span>' +
      '<a href="/task9/' +
      data.id +
      '" target="_blank" class="btn btn-sm btn-secondary" style="margin-left:12px;">Открыть</a>'
    );
  },
  afterSuccess() { loadGenTasks(); },
});

function loadGenTasks() {
  AdminTasks.renderGeneratedTasksList({
    apiBase: '/api/task9',
    playPath: '/task9',
    rowActionsHtml(t) {
      return (
        '<button type="button" class="btn btn-sm" onclick="editTaskFromGen(' +
        t.id +
        ')">Редактировать</button>'
      );
    },
  });
}

async function editTaskFromGen(id) {
  switchTab('tasks', document.querySelectorAll('.tab-btn')[1]);
  await editTask(id);
}

async function deleteGenTask(id) {
  const ok = await AdminTasks.deleteGeneratedTask('/api/task9', id);
  if (ok) loadGenTasks();
}

loadWords();
</script>
