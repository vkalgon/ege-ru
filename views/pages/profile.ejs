/* ─── УЧЕНИК: присоединиться к учителю ────────────────────── */
document.getElementById('join-teacher-btn')?.addEventListener('click', async () => {
  const code = document.getElementById('join-teacher-code').value.trim().toUpperCase();
  const msg = document.getElementById('join-teacher-msg');
  msg.textContent = '';
  msg.className = 'join-msg';
  if (!code) { msg.textContent = 'Введите код'; return; }

  const r = await fetch('/api/student/join-teacher', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ code })
  });
  const data = await r.json();
  if (r.ok) {
    msg.textContent = `Вы присоединились к учителю ${data.teacher_name}!`;
    msg.className = 'join-msg join-msg-success';
    document.getElementById('join-teacher-code').value = '';
    await refreshStudentTeacherSection();
  } else {
    msg.textContent = data.error;
    msg.className = 'join-msg join-msg-error';
  }
});

document.getElementById('detach-teacher-btn')?.addEventListener('click', async () => {
  if (!confirm('Открепиться от учителя?')) return;
  const msg = document.getElementById('detach-teacher-msg');
  msg.textContent = '';
  msg.className = 'join-msg';

  const r = await fetch('/api/student/teacher/detach', { method: 'POST' });
  const data = await r.json();
  if (r.ok) {
    msg.textContent = 'Вы открепились от учителя.';
    msg.className = 'join-msg join-msg-success';
    await refreshStudentTeacherSection();
