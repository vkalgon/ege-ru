/* ─── УЧИТЕЛЬ: вкладки ─────────────────────────────────────── */
function initTeacherTabs() {
  document.querySelectorAll('.teacher-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.teacher-tab').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.teacher-tab-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('teacher-tab-' + btn.dataset.tab).classList.add('active');
      if (btn.dataset.tab === 'generate' || btn.dataset.tab === 'builder') {
        refreshGenerateStudentSelect();
      }
    });
  });
}

/* ─── УЧИТЕЛЬ: список учеников ─────────────────────────────── */
async function loadStudentsList() {
  const res = await fetch('/api/teacher/students');
  const { students } = await res.json();
  teacherStudents = students || [];
  renderStudentsList(teacherStudents);
}

function renderStudentsList(students) {
  const el = document.getElementById('students-list');
  if (!students.length) {
    el.innerHTML = '<p class="empty-state">Учеников пока нет. Добавьте первого по логину или через код приглашения.</p>';
    return;
  }
  el.innerHTML = `
    <div class="students-table">
      <div class="students-table-head">
        <span>Ученик</span>
        <span>Попыток</span>
        <span>Точность</span>
        <span>Освоено</span>
        <span>Повторить</span>
        <span></span>
      </div>
      ${students.map(s => {
        const displayName = s.first_name
          ? s.first_name + (s.last_name ? ' ' + s.last_name : '')
          : (s.username || s.login);
        return `
          <div class="students-table-row" data-id="${s.id}">
            <span class="student-name-cell">
              <strong>${displayName}</strong>
              <small class="text-muted">@${s.login}</small>
            </span>
            <span>${s.total_attempts}</span>
            <span>${s.accuracy}%</span>
            <span class="text-success">${s.mastered_count}</span>
            <span class="text-warning">${s.weak_count}</span>
            <span class="student-actions">
              <button class="btn-small btn-outline" onclick="openStudentDetail(${s.id}, '${displayName.replace(/'/g,"\\'")}')">Детали</button>
              <button class="btn-small btn-generate" onclick="quickGenerate(${s.id}, '${displayName.replace(/'/g,"\\'")}')">Создать ДЗ</button>
              <button class="btn-small btn-danger" onclick="removeStudent(${s.id})">✕</button>
            </span>
          </div>`;
      }).join('')}
    </div>`;
}

document.getElementById('add-student-btn')?.addEventListener('click', async () => {
  const login = document.getElementById('add-student-input').value.trim();
  const errEl = document.getElementById('add-student-error');
  errEl.textContent = '';
  if (!login) { errEl.textContent = 'Введите логин'; return; }

  const res = await fetch('/api/teacher/students', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ login }),
  });
  const data = await res.json();
  if (!res.ok) { errEl.textContent = data.error; return; }

  document.getElementById('add-student-input').value = '';
  teacherStudents.unshift(data.student);
  renderStudentsList(teacherStudents);
  refreshGenerateStudentSelect();
});

async function removeStudent(id) {
  if (!confirm('Убрать ученика из вашего списка?')) return;
  const res = await fetch(`/api/teacher/students/${id}`, { method: 'DELETE' });
  if (!res.ok) return;
  teacherStudents = teacherStudents.filter(s => s.id !== id);
  renderStudentsList(teacherStudents);
  refreshGenerateStudentSelect();
  if (document.getElementById('student-detail-panel').style.display !== 'none')
    document.getElementById('student-detail-panel').style.display = 'none';
}

/* ─── УЧИТЕЛЬ: детали ученика ──────────────────────────────── */
async function openStudentDetail(id, name) {
  const panel = document.getElementById('student-detail-panel');
  const body  = document.getElementById('student-detail-body');
  document.getElementById('student-detail-name').textContent = name;
  panel.style.display = '';
  body.innerHTML = '<div class="skeleton-loader">Загрузка...</div>';
  panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

  const [sr, wr] = await Promise.all([
    fetch(`/api/teacher/students/${id}/stats`),
    fetch(`/api/teacher/students/${id}/weak-words`),
  ]);
  const { summary } = await sr.json();
  const { weak_words, mastery_threshold } = await wr.json();

  const summaryHtml = summary?.length
    ? `<div class="summary-grid mini-summary">
        ${summary.map(s => `
          <div class="summary-card">
            <div class="summary-card-title">${s.label}</div>
            <div class="summary-card-stats">
              <div class="stat-item"><span class="stat-value">${s.completed_tasks ?? 0}</span><span class="stat-label">Решено</span></div>
              <div class="stat-item"><span class="stat-value">${s.accuracy}%</span><span class="stat-label">Точность</span></div>
              <div class="stat-item"><span class="stat-value text-success">${s.mastered_count}</span><span class="stat-label">Освоено</span></div>
              <div class="stat-item"><span class="stat-value text-warning">${s.weak_count}</span><span class="stat-label">Повторить</span></div>
            </div>
            <div class="accuracy-bar"><div class="accuracy-fill" style="width:${s.accuracy}%"></div></div>
          </div>
        `).join('')}
      </div>`
    : '<p class="empty-state">Ученик ещё не решал заданий.</p>';

  body.innerHTML = summaryHtml +
    `<h4 style="margin:20px 0 8px">Слова для повторения</h4>
     <div id="detail-weak-bar" class="weak-tabs-bar"></div>
     <div id="detail-weak-container"></div>`;

  renderWeakWordsTabs(weak_words, mastery_threshold, 'detail-weak-container', 'detail-weak-bar');
}

document.getElementById('student-detail-close')?.addEventListener('click', () => {
  document.getElementById('student-detail-panel').style.display = 'none';
});

/* ─── УЧИТЕЛЬ: ДЗ ──────────────────────────────────────────── */
async function loadHomeworkTeacher() {
  const r = await fetch('/api/teacher/homework');
  const { homework } = await r.json();
  const el = document.getElementById('homework-teacher-list');

  if (!homework?.length) {
    el.innerHTML = '<p class="empty-state">Вы ещё не назначали домашних заданий.</p>';
    return;
  }

  el.innerHTML = homework.map(hw => {
    const studentName = hw.first_name
      ? hw.first_name + (hw.last_name ? ' ' + hw.last_name : '')
      : hw.login;
    const statusLabel = { pending: '⏳ Ожидает', submitted: '✅ Сдано', reviewed: '📋 Проверено' }[hw.status] || hw.status;
    const due = hw.due_date ? new Date(hw.due_date).toLocaleDateString('ru-RU') : 'Без срока';
    return `
      <div class="hw-card hw-status-${hw.status}">
        <div class="hw-card-header">
          <strong>${hw.title}</strong>
          <span class="hw-status-badge">${statusLabel}</span>
        </div>
        <div class="hw-card-meta">
          <span>Ученик: <strong>${studentName}</strong></span>
          <span>Срок: ${due}</span>
          ${hw.submitted_at ? `<span>Сдано: ${new Date(hw.submitted_at).toLocaleDateString('ru-RU')}</span>` : ''}
          ${hw.total_score != null ? `<span>Результат: ${hw.total_score}/${hw.max_score}</span>` : ''}
        </div>
        ${hw.status === 'submitted' ? `
          <div class="hw-review-form">
            <input type="text" placeholder="Комментарий" class="form-input hw-comment-input" id="hw-comment-${hw.id}" style="max-width:300px">
            <button class="btn btn-sm btn-primary" onclick="reviewHomework(${hw.id})">Отметить проверенным</button>
          </div>` : ''}
        ${hw.teacher_comment ? `<div class="hw-comment">Ваш комментарий: ${hw.teacher_comment}</div>` : ''}
      </div>`;
  }).join('');
}

async function reviewHomework(hwId) {
  const comment = document.getElementById(`hw-comment-${hwId}`)?.value.trim();
  const r = await fetch(`/api/teacher/homework/${hwId}/comment`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ comment })
  });
  if (r.ok) loadHomeworkTeacher();
}

/* ─── УЧИТЕЛЬ: генерация задания ───────────────────────────── */
function refreshGenerateStudentSelect() {
  const sel = document.getElementById('gen-student-select');
  const current = sel.value;
  sel.innerHTML = '<option value="">— выберите ученика —</option>' +
    teacherStudents.map(s => {
      const n = s.first_name ? s.first_name + (s.last_name ? ' ' + s.last_name : '') : s.login;
      return `<option value="${s.id}">${n} (@${s.login})</option>`;
    }).join('');
  if (current) sel.value = current;

  const builderSel = document.getElementById('builder-student-select');
  if (builderSel) {
    const currentB = builderSel.value;
    builderSel.innerHTML = '<option value="">— выберите ученика —</option>' +
      teacherStudents.map(s => {
        const n = s.first_name ? s.first_name + (s.last_name ? ' ' + s.last_name : '') : s.login;
        return `<option value="${s.id}">${n} (@${s.login})</option>`;
      }).join('');
    if (currentB) builderSel.value = currentB;
  }
}

async function updateWeakHint() {
  const studentId = document.getElementById('gen-student-select').value;
  const taskType  = document.getElementById('gen-task-select').value;
  const hint = document.getElementById('gen-weak-hint');
  if (!studentId) { hint.style.display = 'none'; return; }

  const wordTable = taskType + '_words';
  const student = teacherStudents.find(s => s.id === Number(studentId));
  if (!student) return;

  if (!student._weakWordCache) {
    const r = await fetch(`/api/teacher/students/${studentId}/weak-words`);
    const d = await r.json();
    student._weakWordCache = d.weak_words || [];
  }
  const group = student._weakWordCache.find(g => g.word_table === wordTable);
  if (group?.words.length) {
    hint.style.display = '';
    hint.textContent = `Слабые места ученика по этому заданию: ${group.words.length} слов(а). Они будут включены в приоритетном порядке.`;
    hint.style.color = '';
  } else {
    hint.style.display = '';
    hint.textContent = 'По этому заданию слабых мест нет — задание будет случайным.';
    hint.style.color = 'var(--text-secondary)';
  }
}

document.getElementById('gen-student-select')?.addEventListener('change', updateWeakHint);
document.getElementById('gen-task-select')?.addEventListener('change', updateWeakHint);

document.getElementById('gen-btn')?.addEventListener('click', async () => {
  const studentId = document.getElementById('gen-student-select').value;
  const taskType  = document.getElementById('gen-task-select').value;
  const count     = Number(document.getElementById('gen-count-input').value) || 1;
  const hwTitle   = document.getElementById('hw-title-input').value.trim();
  const hwDue     = document.getElementById('hw-due-input').value;
  const resultEl  = document.getElementById('gen-result');

  if (!studentId) { alert('Выберите ученика'); return; }

  resultEl.style.display = 'none';
  const btn = document.getElementById('gen-btn');
  btn.disabled = true; btn.textContent = 'Генерирую...';

  try {
    const res = await fetch(`/api/${taskType}/generate`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ tasks_count: count, for_student_id: Number(studentId) }),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Ошибка генерации');

    const ids = data.ids || [data.id];
    const student = teacherStudents.find(s => s.id === Number(studentId));
    const studentName = student ? (student.first_name || student.login) : 'ученика';

    // Если заполнен заголовок ДЗ — создаём ДЗ
    if (hwTitle) {
      await fetch('/api/teacher/homework', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          student_id: Number(studentId),
          title: hwTitle,
          task_type: taskType,
          task_ids: ids,
          due_date: hwDue || null,
        })
      });
      loadHomeworkTeacher();
    }

    resultEl.style.display = '';
    resultEl.innerHTML = `
      <div class="gen-result-header">Готово! ${ids.length} вариант(а) для ${studentName}:${hwTitle ? ' (назначено как ДЗ)' : ''}</div>
      <div class="gen-links">
        ${ids.map((id, i) => `<a href="/${taskType}/${id}" target="_blank" class="gen-link">Вариант ${i + 1} →</a>`).join('')}
      </div>
      <p class="gen-result-hint">Скопируйте ссылки и отправьте ученику${hwTitle ? ', или они уже в разделе ДЗ.' : '.'}`;
  } catch(e) {
    alert(e.message);
  } finally {
    btn.disabled = false; btn.textContent = 'Сгенерировать';
  }
});

/* ─── УЧИТЕЛЬ: Конструктор ДЗ — список + 2 кнопки ─────────────────── */
let _builderTask4CategoriesLoaded = false;
let _builderGridInited = false;
let builderCounts = {};
let _builderTaskMetaByKey = {};
let _builderFlexPrimed = false;

function parseCsvList(str) {
  if (!str) return [];
  return String(str)
    .split(',')
    .map(s => s.trim())
    .filter(Boolean);
}

async function loadTask4CategoriesForBuilder() {
  if (_builderTask4CategoriesLoaded) return;
  const sel = document.getElementById('builder-task4-category');
  if (!sel) return;
  const r = await fetch('/api/task4/categories');
  const cats = await r.json();
  sel.innerHTML = '<option value="">— выберите —</option>' + cats.map(c => `<option value="${c.key}">${c.name}</option>`).join('');
  _builderTask4CategoriesLoaded = true;
