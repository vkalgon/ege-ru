const BUILDER_MAX_BY_TASK = {
  task4: 20,
  task5: 20,
  task7: 20,
  task9: 20,
  task10: 20,
  task11: 20,
  task12: 20,
  task17: 10,
  task18: 10,
  task19: 10,
};

function getBuilderSelected() {
  return Object.entries(builderCounts).filter(([, v]) => Number(v) > 0);
}

function updateBuilderTotalAndButtons() {
  const totalEl = document.getElementById('builderTotalCount');
  const createBtn = document.getElementById('builderCreateBtn');
  const settingsBtn = document.getElementById('builderSettingsBtn');
  const recommendBtn = document.getElementById('builderRecommendBtn');
  const studentId = document.getElementById('builder-student-select')?.value;

  const total = Object.values(builderCounts).reduce((s, v) => s + Number(v || 0), 0);
  totalEl.textContent = total;

  const canRun = total > 0 && !!studentId;
  if (createBtn) createBtn.disabled = !canRun;
  if (settingsBtn) settingsBtn.disabled = total === 0;
  if (recommendBtn) recommendBtn.disabled = !studentId;
}

function clearBuilderRecommendationsHighlight() {
  document.querySelectorAll('.builder-task-card--recommended').forEach(el => {
    el.classList.remove('builder-task-card--recommended');
  });
}

function makeBuilderCard(task) {
  builderCounts[task.key] = 0;
  const maxSelected = Math.min(task.count || 0, BUILDER_MAX_BY_TASK[task.key] ?? 20);
  const isEmpty = maxSelected === 0 || (task.count || 0) === 0;

  const card = document.createElement('div');
  card.className = 'builder-task-card' + (isEmpty ? ' builder-task-card--empty' : '');
  card.dataset.key = task.key;

  card.innerHTML = `
    <div class="builder-task-card__num">Задание ${task.num}</div>
    <div class="builder-task-card__label">${task.label}</div>
    <div class="builder-task-card__available">${isEmpty ? 'Нет заданий' : `доступно: ${task.count}`}</div>
    <div class="builder-task-card__counter">
      <button class="builder-counter-btn" data-action="minus" ${isEmpty ? 'disabled' : ''}>−</button>
      <span class="builder-counter-value" id="bval-${task.key}">0</span>
      <button class="builder-counter-btn" data-action="plus" ${isEmpty ? 'disabled' : ''}>+</button>
    </div>
  `;

  const valEl = card.querySelector(`#bval-${task.key}`);
  const minusBtn = card.querySelector('[data-action="minus"]');
  const plusBtn = card.querySelector('[data-action="plus"]');

  function setCount(n) {
    // Любое ручное изменение — снимаем подсветку рекомендованных типов.
    clearBuilderRecommendationsHighlight();

    const v = Math.max(0, Math.min(maxSelected, Number(n || 0)));
    builderCounts[task.key] = v;
    valEl.textContent = v;
    minusBtn.disabled = v === 0;
    plusBtn.disabled = v >= maxSelected;
    // Карточка должна быть полностью заблокирована только если в принципе нет доступных заданий этого типа.
    card.classList.toggle('builder-task-card--empty', maxSelected === 0);
    // Если пользователь меняет состав варианта — скрываем настройки (они относятся к старому составу).
    const adv = document.getElementById('builder-advanced-config');
    if (adv) adv.style.display = 'none';
    const settingsBtn = document.getElementById('builderSettingsBtn');
    if (settingsBtn) settingsBtn.textContent = '⚙ Настройки';
    updateBuilderTotalAndButtons();
  }

  minusBtn.addEventListener('click', () => setCount(builderCounts[task.key] - 1));
  plusBtn.addEventListener('click', () => setCount(builderCounts[task.key] + 1));

  return card;
}

function getBuilderMaxSelectedByKey(taskKey) {
  const meta = _builderTaskMetaByKey?.[taskKey];
  if (!meta) return 0;
  return Math.min(meta.count || 0, BUILDER_MAX_BY_TASK[taskKey] ?? 20);
}

function setBuilderCountForKey(taskKey, n) {
  const vMax = getBuilderMaxSelectedByKey(taskKey);
  const v = Math.max(0, Math.min(vMax, Number(n || 0)));
  builderCounts[taskKey] = v;

  const valEl = document.getElementById(`bval-${taskKey}`);
  if (valEl) valEl.textContent = String(v);

  const card = document.querySelector(`.builder-task-card[data-key="${taskKey}"]`);
  if (card) {
    // Не блокируем карточку при нуле, если задания этого типа вообще есть.
    card.classList.toggle('builder-task-card--empty', vMax === 0);
    const minusBtn = card.querySelector('[data-action="minus"]');
    const plusBtn = card.querySelector('[data-action="plus"]');
    if (minusBtn) minusBtn.disabled = v === 0;
    if (plusBtn) plusBtn.disabled = v >= vMax;
  }

  // Если состав варианта меняется, скрываем настройки.
  const adv = document.getElementById('builder-advanced-config');
  if (adv) adv.style.display = 'none';
  const settingsBtn2 = document.getElementById('builderSettingsBtn');
  if (settingsBtn2) settingsBtn2.textContent = '⚙ Настройки';
}

function computeRecommendationFromWeakWords(weakWordGroups) {
  // Ожидаем группировку вида: [{ word_table, words: [{...}] }, ...]
  const groups = Array.isArray(weakWordGroups) ? weakWordGroups : [];
  const byKey = new Map();

  // Соотносим таблицы слов с ключами заданий в builder.
  // Остальные типы (где нет weak-words в этом представлении) игнорируем.
  const tableToTaskKey = {
    task4_words: 'task4',
    task9_words: 'task9',
    task10_words: 'task10',
    task11_words: 'task11',
    task12_words: 'task12',
  };

  for (const g of groups) {
    const taskKey = tableToTaskKey[g.word_table];
    if (!taskKey) continue;
    const cnt = Array.isArray(g.words) ? g.words.length : 0;
    if (!cnt) continue;
    byKey.set(taskKey, { taskKey, weight: cnt });
  }

  const types = [...byKey.values()].sort((a, b) => b.weight - a.weight);
  if (types.length === 0) return {};

  const totalWeight = types.reduce((s, t) => s + t.weight, 0);
  // Размер рекомендации ограничиваем разумно, чтобы не превращать builder в "автозалив".
  const recommendedTotal = Math.max(3, Math.min(12, Math.round(totalWeight / 10)));

  // Минимум 1 тип, максимум 4 типа.
  const chosen = types.slice(0, Math.min(4, types.length));
  const chosenCount = chosen.length;

  // Сначала по 1 на каждый тип, остаток распределяем по весу.
  const counts = {};
  for (const t of chosen) counts[t.taskKey] = 1;

  let remaining = recommendedTotal - chosenCount;
  let idx = 0;
  while (remaining > 0 && chosen.length > 0) {
    const t = chosen[idx % chosen.length];
    counts[t.taskKey] = (counts[t.taskKey] || 0) + 1;
    remaining--;
    idx++;
  }

  return counts;
}

async function initTeacherBuilderGrid() {
  if (_builderGridInited) return;
  _builderGridInited = true;

  const grid = document.getElementById('builderTaskGrid');
  const errorEl = document.getElementById('builderErrorMsg');
  const studentSel = document.getElementById('builder-student-select');

  const loading = 'Загрузка…';
  grid.innerHTML = `<div style="color:var(--text-secondary);text-align:center;padding:24px 0;">${loading}</div>`;

  try {
    const cfg = await fetch('/api/variant/config').then(r => r.json());
    grid.innerHTML = '';
    builderCounts = {};
    _builderTaskMetaByKey = {};

    cfg.forEach(t => {
      _builderTaskMetaByKey[t.key] = t;
      grid.appendChild(makeBuilderCard(t));
    });

    updateBuilderTotalAndButtons();
  } catch (e) {
    grid.innerHTML = '<div style="color:#ff6b6b;text-align:center;">Ошибка загрузки</div>';
  }

  studentSel?.addEventListener('change', () => {
    // При смене ученика сбрасываем выбранные типы и скрываем настройки.
    for (const k of Object.keys(builderCounts)) setBuilderCountForKey(k, 0);
    const adv = document.getElementById('builder-advanced-config');
    if (adv) adv.style.display = 'none';
    const settingsBtn = document.getElementById('builderSettingsBtn');
    if (settingsBtn) settingsBtn.textContent = '⚙ Настройки';
    updateBuilderTotalAndButtons();

    const recommendBtn = document.getElementById('builderRecommendBtn');
    if (recommendBtn && !recommendBtn.disabled) recommendBtn.click();
  });
}

function primeBuilderAdvancedFilters() {
  const adv = document.getElementById('builder-advanced-config');
  if (!adv) return;

  const selected = new Set(getBuilderSelected().map(([k]) => k));
  const map = [
    { key: 'task4', checkboxId: 'builder-use-task4' },
    { key: 'task9', checkboxId: 'builder-use-task9' },
    { key: 'task10', checkboxId: 'builder-use-task10' },
    { key: 'task11', checkboxId: 'builder-use-task11' },
    { key: 'task12', checkboxId: 'builder-use-task12' },
  ];

  map.forEach(({ key, checkboxId }) => {
    const cb = document.getElementById(checkboxId);
    if (!cb) return;
    const block = cb.closest('.builder-type');
    const on = selected.has(key);
    cb.checked = on;
    if (block) block.style.display = on ? '' : 'none';

    const countInputId = {
      task4: 'builder-task4-count',
      task9: 'builder-task9-count',
      task10: 'builder-task10-count',
      task11: 'builder-task11-count',
      task12: 'builder-task12-count',
    }[key];
    if (countInputId) {
      const inEl = document.getElementById(countInputId);
      if (inEl) {
        inEl.value = String(builderCounts[key] || 0);
        inEl.disabled = true;
      }
    }
  });

  // Task 4 category select needed only if task4 is selected
  if (selected.has('task4')) {
    loadTask4CategoriesForBuilder();
  }

  adv.style.display = '';
}

async function generateBuilderTasksAndMaybeHomework({ mode }) {
  const studentId = document.getElementById('builder-student-select').value;
  const hwTitle = document.getElementById('builder-hw-title-input').value.trim();
  const hwDue = document.getElementById('builder-hw-due-input').value;
  const resultEl = document.getElementById('builder-result');

  const flexAdv = document.getElementById('builder-advanced-config');

  const selectedEntries = getBuilderSelected();
  if (!selectedEntries.length) {
    alert('Выберите хотя бы один тип задания');
    return;
  }

  const student = teacherStudents.find(s => s.id === Number(studentId));
  const studentName = student ? (student.first_name || student.login) : 'ученика';
  const effectiveHwTitle = hwTitle || `Вариант для ${studentName}`;

  const taskIdsByType = {};
  const variantKeys = new Set(['task17', 'task18', 'task19']);
  const endpointKeys = new Set(['task4', 'task5', 'task7', 'task9', 'task10', 'task11', 'task12']);

  // 1) Генерируем задания через endpoints (4/5/7/9/10/11/12)
  for (const [taskType, countRaw] of selectedEntries) {
    const count = Math.min(Number(countRaw), BUILDER_MAX_BY_TASK[taskType] ?? 20);
    if (!count) continue;

    if (variantKeys.has(taskType)) continue;
    if (!endpointKeys.has(taskType)) continue;

    let payload = {};
    if (taskType === 'task5') {
      payload = { count };
    } else if (taskType === 'task7') {
      payload = { count };
    } else if (taskType === 'task4') {
      payload = {
        tasks_count: count,
        correct_count: 3,
        for_student_id: Number(studentId),
      };
      if (mode === 'flex') {
        payload.correct_count = Number(document.getElementById('builder-task4-correct-count')?.value) || 3;
        const cat = document.getElementById('builder-task4-category')?.value;
        if (cat) payload.category = cat;
      }
    } else if (taskType === 'task9') {
      payload = {
        tasks_count: count,
        correct_count: Number(document.getElementById('builder-task9-correct-count')?.value) || 3,
        for_student_id: Number(studentId),
      };
      if (mode !== 'flex') {
        payload.correct_count = 3;
      } else {
        const categories = Array.from(document.querySelectorAll('.builder-task9-category'))
          .filter(cb => cb.checked).map(cb => cb.value);
        const alternationTypes = Array.from(document.querySelectorAll('.builder-task9-alt-type'))
          .filter(cb => cb.checked).map(cb => cb.value);
        const vowelPairs = parseCsvList(document.getElementById('builder-task9-vowel-pairs')?.value).slice(0, 50);
        payload.categories = categories;
        payload.alternation_types = alternationTypes;
        if (vowelPairs.length) payload.vowel_pairs = vowelPairs;
      }
    } else if (taskType === 'task10') {
      payload = {
        tasks_count: count,
        correct_count: 3,
        for_student_id: Number(studentId),
      };
      if (mode === 'flex') {
        payload.correct_count = Number(document.getElementById('builder-task10-correct-count')?.value) || 3;
        const allTask10Rules = ['з/с','ъ/ь','пре/при','пра/про','ы/и','неизменяемые гласные','неизменяемые согласные'];
        const rules = Array.from(document.querySelectorAll('.builder-task10-rule'))
          .filter(cb => cb.checked).map(cb => cb.value);
        if (rules.length > 0 && rules.length < allTask10Rules.length) payload.rules = rules;
      }
    } else if (taskType === 'task11') {
      payload = {
        tasks_count: count,
        correct_count: 3,
        for_student_id: Number(studentId),
      };
      if (mode === 'flex') {
        payload.correct_count = Number(document.getElementById('builder-task11-correct-count')?.value) || 3;
        const allTask11Suffixes = ['ова/ыва','перед_вш','обес/обез','лив/чив','еньк/оньк','еват/оват','ист','ев/ив','к/ск','инк/енк','ик/ек','ец/иц','изн/от/ин','о/ё_шип','о/а_нар'];
        const suffixes = Array.from(document.querySelectorAll('.builder-task11-suffix'))
          .filter(cb => cb.checked).map(cb => cb.value);
        if (suffixes.length > 0 && suffixes.length < allTask11Suffixes.length) payload.rules = suffixes;
      }
    } else if (taskType === 'task12') {
      payload = {
        tasks_count: count,
        correct_count: 3,
        for_student_id: Number(studentId),
      };
      if (mode === 'flex') {
        payload.correct_count = Number(document.getElementById('builder-task12-correct-count')?.value) || 3;
        const vowelPairs = parseCsvList(document.getElementById('builder-task12-vowel-pairs')?.value).slice(0, 80);
        const allTask12FormTypes = ['verb','active_part','passive_part'];
        const formTypes = Array.from(document.querySelectorAll('.builder-task12-form-type'))
          .filter(cb => cb.checked).map(cb => cb.value);
        if (vowelPairs.length) payload.vowel_pairs = vowelPairs;
        if (formTypes.length > 0 && formTypes.length < allTask12FormTypes.length) payload.form_types = formTypes;
      }
    }

    const res = await fetch(`/api/${taskType}/generate`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || `Ошибка генерации ${taskType}`);

    const ids = data.ids || [data.id];
    taskIdsByType[taskType] = ids;
  }

  // 2) Генерируем task17/18/19 через /api/variant/generate
  const variantPick = {};
  for (const [taskType, countRaw] of selectedEntries) {
    if (!variantKeys.has(taskType)) continue;
    variantPick[taskType] = Math.min(Number(countRaw), BUILDER_MAX_BY_TASK[taskType] ?? 10);
  }

  let variantTasks = [];
  if (Object.keys(variantPick).length) {
    const vr = await fetch('/api/variant/generate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(variantPick),
    });
    const vrData = await vr.json();
    if (!vr.ok) throw new Error(vrData.error || 'Ошибка генерации варианта для 17/18/19');

    const tasksResp = await fetch(`/api/variant/${vrData.id}`).then(r => r.json());
    variantTasks = tasksResp.tasks || [];
  }

  for (const t of variantTasks) {
    const type = t.type;
    if (!taskIdsByType[type]) taskIdsByType[type] = [];
    taskIdsByType[type].push(t.taskId);
  }

  // 3) Собираем единый вариант из уже сгенерированных taskIdsByType
  const flatTasks = [];
  for (const [taskType, ids] of Object.entries(taskIdsByType)) {
    if (!ids?.length) continue;
    for (const id of ids) {
      flatTasks.push({ type: taskType, taskId: id });
    }
  }

  if (!flatTasks.length) {
    throw new Error('Не удалось собрать задания для варианта');
  }

  const vr2 = await fetch('/api/variant/from-tasks', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ tasks: flatTasks }),
  });
  const vr2Data = await vr2.json();
  if (!vr2.ok) throw new Error(vr2Data.error || 'Ошибка создания варианта');

  const variantId = vr2Data.id;

  // 4) Создаём ОДНО ДЗ на этот вариант (с дефолтным title, если поле пустое)
  if (variantId) {
    await fetch('/api/teacher/homework', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        student_id: Number(studentId),
        title: effectiveHwTitle,
        task_type: 'variant',
        task_ids: [variantId],
        due_date: hwDue || null,
      }),
    });
  }

  // 5) Показываем результат с единой ссылкой на вариант
  resultEl.style.display = '';
  const assignedText = ' (назначено как ДЗ)';
  const total = flatTasks.length;
  resultEl.innerHTML = `
    <div class="gen-result-header">Готово! Сформирован вариант из ${total} заданий для ${studentName}${assignedText}</div>
    <div class="gen-links">
      <a href="/variant/${variantId}" target="_blank" class="gen-link">
        Открыть вариант #${variantId} →
      </a>
    </div>
    <p class="gen-result-hint">Скопируйте ссылку и отправьте ученику, или он увидит вариант в разделе ДЗ личного кабинета.</p>
  `;

  await loadHomeworkTeacher();
  document.querySelector('[data-tab="homework"]').click();
}

document.getElementById('builderCreateBtn')?.addEventListener('click', async () => {
  const createBtn = document.getElementById('builderCreateBtn');
  const adv = document.getElementById('builder-advanced-config');
  // Если панель настроек открыта — используем гибкий режим, иначе быстрый.
  const mode = (adv && adv.style.display !== 'none') ? 'flex' : 'quick';

  const errEl = document.getElementById('builderErrorMsg');
  if (errEl) errEl.hidden = true;

  try {
    createBtn.disabled = true;
    createBtn.textContent = 'Создание…';
    await generateBuilderTasksAndMaybeHomework({ mode });
  } catch (e) {
    if (errEl) { errEl.hidden = false; errEl.textContent = e.message || 'Ошибка'; }
  } finally {
    createBtn.disabled = false;
    createBtn.textContent = 'Создать ДЗ';
  }
});

document.getElementById('builderRecommendBtn')?.addEventListener('click', async () => {
  const recommendBtn = document.getElementById('builderRecommendBtn');
  const studentId = document.getElementById('builder-student-select')?.value;
  const errEl = document.getElementById('builderErrorMsg');

  if (!studentId) return;

  try {
    recommendBtn.disabled = true;
    if (errEl) errEl.hidden = true;

    const r = await fetch(`/api/teacher/students/${studentId}/weak-words`);
    if (!r.ok) throw new Error('Не удалось загрузить ошибки ученика');
    const data = await r.json();

    const weakWordGroups = data?.weak_words || [];
    let reco = computeRecommendationFromWeakWords(weakWordGroups);

    // Если weak-words пустой, делаем "разумную" подстановку по доступным типам.
    if (!Object.keys(reco).length) {
      const fallbackOrder = ['task9', 'task10', 'task11', 'task12', 'task4'];
      reco = {};
      let used = 0;
      for (const key of fallbackOrder) {
        const max = getBuilderMaxSelectedByKey(key);
        if (max <= 0) continue;
        reco[key] = 1;
        used++;
        if (used >= 3) break;
      }
    }

    // Сбросим всё, потом применим рекомендации.
    for (const k of Object.keys(builderCounts)) setBuilderCountForKey(k, 0);
    clearBuilderRecommendationsHighlight();
    for (const [k, v] of Object.entries(reco)) {
      setBuilderCountForKey(k, v);
      if (v > 0 && getBuilderMaxSelectedByKey(k) > 0) {
        const card = document.querySelector(`.builder-task-card[data-key="${k}"]`);
        card?.classList.add('builder-task-card--recommended');
      }
    }

    // Обновим общий счётчик и доступность кнопок.
    updateBuilderTotalAndButtons();
  } catch (e) {
    if (errEl) {
      errEl.hidden = false;
      errEl.textContent = e.message || 'Ошибка';
    }
  } finally {
    if (recommendBtn) recommendBtn.disabled = false;
    // Состояние кнопок выставит updateBuilderTotalAndButtons().
  }
});

document.getElementById('builderSettingsBtn')?.addEventListener('click', () => {
  const settingsBtn = document.getElementById('builderSettingsBtn');
  const adv = document.getElementById('builder-advanced-config');
  if (!adv) return;

  const isOpen = adv.style.display !== 'none';
  if (isOpen) {
    adv.style.display = 'none';
    settingsBtn.textContent = '⚙ Настройки';
  } else {
    primeBuilderAdvancedFilters();
    adv.style.display = '';
    settingsBtn.textContent = '⚙ Скрыть настройки';
  }
});

function quickGenerate(studentId, studentName) {
  document.querySelectorAll('.teacher-tab').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.teacher-tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelector('[data-tab="generate"]').classList.add('active');
  document.getElementById('teacher-tab-generate').classList.add('active');
  refreshGenerateStudentSelect();
  document.getElementById('gen-student-select').value = studentId;
  updateWeakHint();
}

/* ─── Модальное окно: слова по заданию ────────────────────── */
let _weakWordsCache = null;
let _masteryThresholdCache = 5;

async function getWeakWordsData() {
  if (_weakWordsCache) return _weakWordsCache;
  const r = await fetch('/api/progress/weak-words');
  const data = await r.json();
  _weakWordsCache = data.weak_words || [];
  _masteryThresholdCache = data.mastery_threshold || 5;
  return _weakWordsCache;
}

async function openWordsModal(taskKey, taskLabel) {
  const overlay = document.getElementById('words-modal-overlay');
  const body = document.getElementById('words-modal-body');
  document.getElementById('words-modal-title').textContent = taskLabel + ' — слова для повторения';
  body.innerHTML = '<div class="skeleton-loader">Загрузка...</div>';
  overlay.style.display = 'flex';
  document.body.style.overflow = 'hidden';

  const wordTable = taskKey + '_words';
  const weakWords = await getWeakWordsData();
  const group = weakWords.find(g => g.word_table === wordTable);

  renderWordsModalBody(body, group?.words || [], wordTable);
}

function renderWordsModalBody(body, words, wordTable) {
  if (!words.length) {
    body.innerHTML = '<p class="empty-state">Слов для повторения нет — отличная работа!</p>';
    return;
  }

  body.innerHTML = words.map(w => `
    <div class="wm-word-item" id="wm-word-${wordTable}-${w.word_id}">
      <div class="wm-word-top">
        <span class="wm-word-text">${w.word}</span>
        <span class="weak-word-errors">${w.errors} ${pluralErrors(w.errors)}</span>
      </div>
      <div class="weak-word-rule">${w.rule}</div>
      <div class="mastery-bar-wrap">
        <div class="mastery-bar"><div class="mastery-fill" style="width:${w.mastery}%"></div></div>
        <span class="mastery-label">${w.streak}/${_masteryThresholdCache} подряд</span>
      </div>
      <div class="wm-word-actions">
        <button class="btn btn-sm btn-outline" onclick="masterWord('${wordTable}', ${w.word_id})">Отметить запомненным</button>
        <button class="btn btn-sm btn-ghost wm-delete-btn" onclick="deleteWord('${wordTable}', ${w.word_id})">Удалить</button>
      </div>
    </div>
  `).join('');
}

async function deleteWord(wordTable, wordId) {
  const r = await fetch(`/api/progress/words/${wordTable}/${wordId}`, { method: 'DELETE' });
  if (!r.ok) return;
  _weakWordsCache = null; // сбросить кеш
  document.getElementById(`wm-word-${wordTable}-${wordId}`)?.remove();
  const body = document.getElementById('words-modal-body');
  if (!body.querySelector('.wm-word-item')) {
    body.innerHTML = '<p class="empty-state">Слов для повторения нет — отличная работа!</p>';
  }
  loadStudentData(); // обновить карточки
}

async function masterWord(wordTable, wordId) {
  const r = await fetch(`/api/progress/words/${wordTable}/${wordId}/master`, { method: 'POST' });
  if (!r.ok) return;
  _weakWordsCache = null;
  document.getElementById(`wm-word-${wordTable}-${wordId}`)?.remove();
  const body = document.getElementById('words-modal-body');
  if (!body.querySelector('.wm-word-item')) {
    body.innerHTML = '<p class="empty-state">Слов для повторения нет — отличная работа!</p>';
  }
  loadStudentData();
}

function closeWordsModal(e) {
  if (e && e.target !== document.getElementById('words-modal-overlay')) return;
  document.getElementById('words-modal-overlay').style.display = 'none';
  document.body.style.overflow = '';
}

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closeWordsModal();
});
