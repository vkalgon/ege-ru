<header class="site-header">
  <a href="/" class="site-header__logo" aria-label="Главная">
    <img src="/images/logo.svg" alt="" class="logo-bg"/>
  </a>

  <nav class="site-nav" aria-label="Главная навигация">
    <a class="site-nav__link" href="/">Главная</a>
    <a class="site-nav__link" href="#">Задания</a>
    <a class="site-nav__link" href="/theory">Теория</a>
    <a class="site-nav__link" href="#">Прогресс</a>
  </nav>

  <button class="theme-toggle" id="theme-toggle" aria-label="Переключить тему">
    <span class="theme-toggle__icon theme-toggle__icon--light">☀️</span>
    <span class="theme-toggle__icon theme-toggle__icon--dark">🌙</span>
  </button>

  <div class="site-auth" id="auth-section">
    <!-- Для неавторизованных пользователей -->
    <div id="guest-auth" style="display: none;">
      <a href="/login" class="site-nav__link">Войти</a>
    </div>
    
    <!-- Для авторизованных пользователей -->
    <div id="user-auth" style="display: none;">
      <div class="site-auth__avatar" aria-hidden="true">
        <img id="user-avatar-img" alt="Аватар" style="display:none;width:100%;height:100%;object-fit:cover;border-radius:50%;" />
        <span id="user-avatar">В</span>
      </div>
      <span class="site-auth__chevron" aria-hidden="true">
        <img src="/images/chevron-down.svg" alt="Стрелка вниз"/>
      </span>
      <div class="user-menu" id="user-menu" style="display: none;">
        <div class="user-menu__info">
          <div class="user-menu__name" id="user-name">Пользователь</div>
          <div class="user-menu__email" id="user-contact"></div>
        </div>
        <div class="user-menu__actions">
          <a class="user-menu__action" href="/profile" style="display:block;text-align:left;text-decoration:none;cursor:pointer">Личный кабинет</a>
          <button class="user-menu__action" onclick="logout()">Выйти</button>
        </div>
      </div>
    </div>
  </div>
</header>
